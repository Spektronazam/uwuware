            end
        end)
        bg.InputEnded:Connect(function(inp: InputObject)
            if inp.UserInputType == Enum.UserInputType.MouseMovement and not dragging then
                tween(bg, TWEEN_NORMAL, { ImageColor3 = Color3.fromRGB(20, 20, 20) })
            end
        end)

        return bg, txt
    end

    local resetBtn, _resetTxt = makeActionBtn(92, "Reset")
    local undoBtn, _undoTxt = makeActionBtn(112, "Undo")
    local setBtn, _setTxt = makeActionBtn(132, "Set")
    local rainbowBtn, rainbowTxt = makeActionBtn(152, "Rainbow")

    option.resetColor = resetBtn
    option.undoColor = undoBtn
    option.setColor = setBtn
    option.rainbow = rainbowBtn
    option.rainbowText = rainbowTxt

    resetBtn.InputBegan:Connect(function(inp: InputObject)
        if inp.UserInputType == Enum.UserInputType.MouseButton1 and not rainbowEnabled then
            previousColors = { originalColor }
            option:SetColor(originalColor)
        end
    end)

    undoBtn.InputBegan:Connect(function(inp: InputObject)
        if inp.UserInputType == Enum.UserInputType.MouseButton1 and not rainbowEnabled then
            local num = if #previousColors == 1 then 0 else 1
            option:SetColor(previousColors[#previousColors - num])
            if #previousColors ~= 1 then
                table.remove(previousColors, #previousColors)
            end
        end
    end)

    setBtn.InputBegan:Connect(function(inp: InputObject)
        if inp.UserInputType == Enum.UserInputType.MouseButton1 and not rainbowEnabled then
            table.insert(previousColors, currentColor)
            option:SetColor(currentColor)
        end
    end)

    rainbowBtn.InputBegan:Connect(function(inp: InputObject)
        if inp.UserInputType == Enum.UserInputType.MouseButton1 then
            rainbowEnabled = not rainbowEnabled
            if rainbowEnabled then
                rainbowLoop = RunService.Heartbeat:Connect(function()
                    option:SetColor(chromaColor)
                    rainbowTxt.TextColor3 = chromaColor
                end)
            else
                if rainbowLoop then rainbowLoop:Disconnect() end
                option:SetColor(previousColors[#previousColors])
                rainbowTxt.TextColor3 = Color3.fromRGB(255, 255, 255)
            end
        end
    end)

    return option
end

-- ═══════════════════ COLOR PICKER (inline) ═══════════════════
local function createColor(option: OptionBase, parent: any, _holder: any?)
    option.main = library:Create("TextLabel", {
        LayoutOrder = option.position,
        Size = UDim2.new(1, 0, 0, 31),
        BackgroundTransparency = 1,
        Text = " " .. option.text,
        TextSize = 17,
        Font = Enum.Font.Gotham,
        TextColor3 = Color3.fromRGB(255, 255, 255),
        TextXAlignment = Enum.TextXAlignment.Left,
        Parent = parent.content,
    }) :: TextLabel

    local colorBoxOutline = library:Create("ImageLabel", {
        Position = UDim2.new(1, -6, 0, 4),
        Size = UDim2.new(-1, 10, 1, -10),
        SizeConstraint = Enum.SizeConstraint.RelativeYY,
        BackgroundTransparency = 1,
        Image = "rbxassetid://3570695787",
        ImageColor3 = Color3.fromRGB(100, 100, 100),
        ScaleType = Enum.ScaleType.Slice,
        SliceCenter = Rect.new(100, 100, 100, 100),
        SliceScale = 0.02,
        Parent = option.main,
    }) :: ImageLabel

    option.visualize = library:Create("ImageLabel", {
        Position = UDim2.fromOffset(2, 2),
        Size = UDim2.new(1, -4, 1, -4),
        BackgroundTransparency = 1,
        Image = "rbxassetid://3570695787",
        ImageColor3 = option.color,
        ScaleType = Enum.ScaleType.Slice,
        SliceCenter = Rect.new(100, 100, 100, 100),
        SliceScale = 0.02,
        Parent = colorBoxOutline,
    }) :: ImageLabel

    local inContact = false

    option.main.InputBegan:Connect(function(input: InputObject)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            if not option.mainHolder then createColorPickerWindow(option) end
            if library.activePopup then library.activePopup:Close() end
            local pos = option.main.AbsolutePosition
            option.mainHolder.Position = UDim2.fromOffset(pos.X - 5, pos.Y - 10)
            option.open = true
            option.mainHolder.Visible = true
            library.activePopup = option
            tween(option.mainHolder, TWEEN_SMOOTH, { ImageTransparency = 0, Position = UDim2.fromOffset(pos.X - 5, pos.Y - 4) })
            tween(option.mainHolder, TweenInfo.new(0.4, Enum.EasingStyle.Quad, Enum.EasingDirection.Out, 0, false, 0.1), { Position = UDim2.fromOffset(pos.X - 5, pos.Y + 1) })
            tween(option.satval, TWEEN_SMOOTH, { BackgroundTransparency = 0 })
            for _, obj in option.mainHolder:GetDescendants() do
                if obj:IsA("TextLabel") then
                    tween(obj, TWEEN_SMOOTH, { TextTransparency = 0 })
                elseif obj:IsA("ImageLabel") then
                    tween(obj, TWEEN_SMOOTH, { ImageTransparency = 0 })
                elseif obj:IsA("Frame") then
                    tween(obj, TWEEN_SMOOTH, { BackgroundTransparency = 0 })
                end
            end
        end
        if input.UserInputType == Enum.UserInputType.MouseMovement then
            inContact = true
            if not option.open then
                tween(colorBoxOutline, TWEEN_QUICK, { ImageColor3 = Color3.fromRGB(140, 140, 140) })
            end
        end
    end)

    option.main.InputEnded:Connect(function(input: InputObject)
        if input.UserInputType == Enum.UserInputType.MouseMovement then
            inContact = false
            if not option.open then
                tween(colorBoxOutline, TWEEN_QUICK, { ImageColor3 = Color3.fromRGB(100, 100, 100) })
            end
        end
    end)

    function option:SetColor(newColor: Color3)
        if self.mainHolder then self:updateVisuals(newColor) end
        self.visualize.ImageColor3 = newColor
        library.flags[self.flag] = newColor
        self.color = newColor
        self.callback(newColor)
    end

    function option:Close()
        library.activePopup = nil
        self.open = false
        local pos = self.main.AbsolutePosition
        tween(self.mainHolder, TWEEN_SMOOTH, { ImageTransparency = 1, Position = UDim2.fromOffset(pos.X - 5, pos.Y - 10) })
        tween(self.satval, TWEEN_SMOOTH, { BackgroundTransparency = 1 })
        for _, obj in self.mainHolder:GetDescendants() do
            if obj:IsA("TextLabel") then
                tween(obj, TWEEN_SMOOTH, { TextTransparency = 1 })
            elseif obj:IsA("ImageLabel") then
                tween(obj, TWEEN_SMOOTH, { ImageTransparency = 1 })
            elseif obj:IsA("Frame") then
                tween(obj, TWEEN_SMOOTH, { BackgroundTransparency = 1 })
            end
        end
        task.delay(0.3, function()
            if not self.open then
                self.mainHolder.Visible = false
            end
        end)
    end
end

------------------------------ Load options recursively -------------------
local function loadOptions(optionHolder: any, holder: any?)
    for _, opt in optionHolder.options do
        if opt.type == "label" then
            createLabel(opt, optionHolder)
        elseif opt.type == "toggle" then
            createToggle(opt, optionHolder)
        elseif opt.type == "button" then
            createButton(opt, optionHolder)
        elseif opt.type == "list" then
            createList(opt, optionHolder, holder)
        elseif opt.type == "box" then
            createBox(opt, optionHolder)
        elseif opt.type == "bind" then
            createBind(opt, optionHolder)
        elseif opt.type == "slider" then
            createSlider(opt, optionHolder)
        elseif opt.type == "color" then
            createColor(opt, optionHolder, holder)
        elseif opt.type == "folder" then
            opt:init()
        end
    end
end

------------------------------ Register option methods --------------------
local function addMethods(parent: any)
    function parent:AddLabel(option: { [string]: any }?)
        local o: any = if typeof(option) == "table" then option else {}
        o.text = tostring(o.text)
        o.type = "label"
        o.position = #self.options
        table.insert(self.options, o)
        return o
    end

    function parent:AddToggle(option: { [string]: any }?)
        local o: any = if typeof(option) == "table" then option else {}
        o.text = tostring(o.text)
        o.state = if typeof(o.state) == "boolean" then o.state else false
        o.callback = if typeof(o.callback) == "function" then o.callback else function() end
        o.type = "toggle"
        o.position = #self.options
        o.flag = o.flag or o.text
        library.flags[o.flag] = o.state
        table.insert(self.options, o)
        return o
    end

    function parent:AddButton(option: { [string]: any }?)
        local o: any = if typeof(option) == "table" then option else {}
        o.text = tostring(o.text)
        o.callback = if typeof(o.callback) == "function" then o.callback else function() end
        o.type = "button"
        o.position = #self.options
        o.flag = o.flag or o.text
        table.insert(self.options, o)
        return o
    end

    function parent:AddBind(option: { [string]: any }?)
        local o: any = if typeof(option) == "table" then option else {}
        o.text = tostring(o.text)
        o.key = (if o.key and typeof(o.key) == "EnumItem" then o.key.Name else o.key) or "F"
        o.hold = if typeof(o.hold) == "boolean" then o.hold else false
        o.callback = if typeof(o.callback) == "function" then o.callback else function() end
        o.type = "bind"
        o.position = #self.options
        o.flag = o.flag or o.text
        library.flags[o.flag] = o.key
        table.insert(self.options, o)
        return o
    end

    function parent:AddSlider(option: { [string]: any }?)
        local o: any = if typeof(option) == "table" then option else {}
        o.text = tostring(o.text)
        o.min = if typeof(o.min) == "number" then o.min else 0
        o.max = if typeof(o.max) == "number" then o.max else 0
        o.dual = if typeof(o.dual) == "boolean" then o.dual else false
        o.value = math.clamp(if typeof(o.value) == "number" then o.value else o.min, o.min, o.max)
        o.value2 = if typeof(o.value2) == "number" then o.value2 else o.max
        o.callback = if typeof(o.callback) == "function" then o.callback else function() end
        o.float = if typeof(o.float) == "number" then o.float else 1
        o.type = "slider"
        o.position = #self.options
        o.flag = o.flag or o.text
        library.flags[o.flag] = o.value
        table.insert(self.options, o)
        return o
    end

    function parent:AddList(option: { [string]: any }?)
        local o: any = if typeof(option) == "table" then option else {}
        o.text = tostring(o.text)
        o.values = if typeof(o.values) == "table" then o.values else {}
        o.value = tostring(o.value or o.values[1] or "")
        o.callback = if typeof(o.callback) == "function" then o.callback else function() end
        o.open = false
        o.type = "list"
        o.position = #self.options
        o.flag = o.flag or o.text
        library.flags[o.flag] = o.value
        table.insert(self.options, o)
        return o
    end

    function parent:AddBox(option: { [string]: any }?)
        local o: any = if typeof(option) == "table" then option else {}
        o.text = tostring(o.text)
        o.value = tostring(o.value or "")
        o.callback = if typeof(o.callback) == "function" then o.callback else function() end
        o.type = "box"
        o.position = #self.options
        o.flag = o.flag or o.text
        library.flags[o.flag] = o.value
        table.insert(self.options, o)
        return o
    end

    function parent:AddColor(option: { [string]: any }?)
        local o: any = if typeof(option) == "table" then option else {}
        o.text = tostring(o.text)
        o.color = if typeof(o.color) == "table"
            then Color3.new(tonumber(o.color[1]) or 1, tonumber(o.color[2]) or 1, tonumber(o.color[3]) or 1)
            else (o.color or Color3.new(1, 1, 1))
        o.callback = if typeof(o.callback) == "function" then o.callback else function() end
        o.open = false
        o.type = "color"
        o.position = #self.options
        o.flag = o.flag or o.text
        library.flags[o.flag] = o.color
        table.insert(self.options, o)
        return o
    end

    function parent:AddFolder(title: string)
        local o: any = {}
        o.title = tostring(title)
        o.options = {}
        o.open = false
        o.type = "folder"
        o.position = #self.options
        table.insert(self.options, o)
        addMethods(o)

        function o:init()
            createOptionHolder(self.title, parent.content, self, true)
            loadOptions(self, parent)
        end

        return o
    end
end

------------------------------ Window creation ----------------------------
function library:CreateWindow(title: string)
    local window: any = {
        title = tostring(title),
        options = {},
        open = true,
        canInit = true,
        init = false,
        position = #self.windows,
    }
    addMethods(window)
    table.insert(self.windows, window)
