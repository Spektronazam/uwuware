------------------------------ Utility helpers ------------------------------
local function round(num: number, bracket: number?): number
    local b = bracket or 1
    local a = math.floor(num / b + math.sign(num) * 0.5) * b
    if a < 0 then a += b end
    return a
end

local function contains<T>(list: { T }, item: T): boolean
    for _, v in list do
        if v == item then return true end
    end
    return false
end

local function tween(obj: Instance, info: TweenInfo, props: { [string]: any })
    TweenService:Create(obj, info, props):Play()
end

local function tweenWait(obj: Instance, info: TweenInfo, props: { [string]: any })
    local tw = TweenService:Create(obj, info, props)
    tw:Play()
    tw.Completed:Wait()
end

local function updateDrag(input: InputObject)
    if not dragObject or not dragStart or not startPos then return end
    local delta = input.Position - dragStart
    local yPos = math.max(startPos.Y.Offset + delta.Y, -36)
    local target = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, yPos)
    tween(dragObject, TWEEN_QUICK, { Position = target })
end

------------------------------ Instance creation helper --------------------
function library:Create(class: string, properties: { [string]: any }?): Instance
    local props = properties or {}
    local inst = Instance.new(class)
    for prop, value in props do
        (inst :: any)[prop] = value
    end
    return inst
end

------------------------------ Loading throbber ----------------------------
local function createThrobber(parent: ScreenGui): { spinner: ImageLabel, bg: Frame, destroy: () -> () }
    local bg = library:Create("Frame", {
        Name = "LoadingBG",
        Size = UDim2.fromScale(1, 1),
        BackgroundColor3 = Color3.fromRGB(12, 12, 12),
        BackgroundTransparency = 1,
        ZIndex = 200,
        Parent = parent,
    }) :: Frame

    local spinner = library:Create("ImageLabel", {
        Name = "Throbber",
        AnchorPoint = Vector2.new(0.5, 0.5),
        Position = UDim2.fromScale(0.5, 0.5),
        Size = UDim2.fromOffset(40, 40),
        BackgroundTransparency = 1,
        Image = "rbxassetid://4965945816", -- a simple spinner ring
        ImageColor3 = ACCENT,
        ImageTransparency = 1,
        ZIndex = 201,
        Parent = bg,
    }) :: ImageLabel

    -- fade bg in
    tween(bg, TWEEN_FADE, { BackgroundTransparency = 0.15 })
    -- fade spinner in
    tween(spinner, TWEEN_FADE, { ImageTransparency = 0 })

    -- spin loop
    local spinning = true
    local speed = 360 -- deg/sec
    task.spawn(function()
        while spinning do
            spinner.Rotation += speed * task.wait()
        end
    end)

    local function destroy()
        -- slow down spinner
        task.spawn(function()
            for i = speed, 0, -20 do
                speed = i
                task.wait(0.02)
            end
            spinning = false
        end)
        -- fade out
        tween(spinner, TweenInfo.new(0.6, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), { ImageTransparency = 1 })
        tween(bg, TweenInfo.new(0.6, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), { BackgroundTransparency = 1 })
        task.delay(0.65, function()
            bg:Destroy()
        end)
    end

    return { spinner = spinner, bg = bg, destroy = destroy }
end

------------------------------ Option holder creation ----------------------
local function createOptionHolder(holderTitle: string, parent: Instance, parentTable: any, subHolder: boolean?)
    local size: number = if subHolder then 34 else 40

    parentTable.main = library:Create("ImageButton", {
        LayoutOrder = if subHolder then parentTable.position else 0,
        Position = UDim2.fromOffset(20 + (DEFAULT_WINDOW_W + 20) * (parentTable.position or 0), 20),
        Size = UDim2.fromOffset(DEFAULT_WINDOW_W, size),
        BackgroundTransparency = 1,
        Image = "rbxassetid://3570695787",
        ImageColor3 = Color3.fromRGB(20, 20, 20),
        ScaleType = Enum.ScaleType.Slice,
        SliceCenter = Rect.new(100, 100, 100, 100),
        SliceScale = 0.04,
        ClipsDescendants = true,
        AutoButtonColor = false,
        -- start invisible for the intro animation
        ImageTransparency = if subHolder then 0 else 1,
        Parent = parent,
    }) :: ImageButton

    local mainBtn: ImageButton = parentTable.main :: ImageButton

    -- Store original position for undo-on-exit
    if not subHolder then
        library._originalPositions[mainBtn] = mainBtn.Position
        library._originalSizes[mainBtn] = mainBtn.Size
    end

    local roundLabel: ImageLabel? = nil
    if not subHolder then
        roundLabel = library:Create("ImageLabel", {
            Size = UDim2.new(1, 0, 0, size),
            BackgroundTransparency = 1,
            Image = "rbxassetid://3570695787",
            ImageColor3 = if parentTable.open then Color3.fromRGB(10, 10, 10) else Color3.fromRGB(6, 6, 6),
            ScaleType = Enum.ScaleType.Slice,
            SliceCenter = Rect.new(100, 100, 100, 100),
            SliceScale = 0.04,
            Parent = mainBtn,
        }) :: ImageLabel
    end

    local title = library:Create("TextLabel", {
        Size = UDim2.new(1, 0, 0, size),
        BackgroundTransparency = if subHolder then 0 else 1,
        BackgroundColor3 = Color3.fromRGB(10, 10, 10),
        BorderSizePixel = 0,
        Text = holderTitle,
        TextSize = if subHolder then 16 else 17,
        Font = Enum.Font.GothamBold,
        TextColor3 = Color3.fromRGB(255, 255, 255),
        Parent = mainBtn,
    }) :: TextLabel

    local closeHolder = library:Create("Frame", {
        Position = UDim2.new(1, 0, 0, 0),
        Size = UDim2.new(-1, 0, 1, 0),
        SizeConstraint = Enum.SizeConstraint.RelativeYY,
        BackgroundTransparency = 1,
        Parent = title,
    }) :: Frame

    local close = library:Create("ImageLabel", {
        AnchorPoint = Vector2.new(0.5, 0.5),
        Position = UDim2.fromScale(0.5, 0.5),
        Size = UDim2.new(1, -size - 10, 1, -size - 10),
        Rotation = if parentTable.open then 90 else 180,
        BackgroundTransparency = 1,
        Image = "rbxassetid://4918373417",
        ImageColor3 = if parentTable.open then Color3.fromRGB(50, 50, 50) else Color3.fromRGB(30, 30, 30),
        ScaleType = Enum.ScaleType.Fit,
        Parent = closeHolder,
    }) :: ImageLabel

    -- Resize grip (bottom-right corner) — only for top-level windows
    local resizeGrip: Frame? = nil
    if not subHolder then
        resizeGrip = library:Create("Frame", {
            Name = "ResizeGrip",
            AnchorPoint = Vector2.new(1, 1),
            Position = UDim2.new(1, 0, 1, 0),
            Size = UDim2.fromOffset(14, 14),
            BackgroundTransparency = 1,
            ZIndex = 10,
            Parent = mainBtn,
        }) :: Frame

        -- visual indicator: small triangle
        library:Create("Frame", {
            AnchorPoint = Vector2.new(1, 1),
            Position = UDim2.new(1, -2, 1, -2),
            Size = UDim2.fromOffset(8, 2),
            BackgroundColor3 = Color3.fromRGB(60, 60, 60),
            BorderSizePixel = 0,
            ZIndex = 11,
            Parent = resizeGrip,
        })
        library:Create("Frame", {
            AnchorPoint = Vector2.new(1, 1),
            Position = UDim2.new(1, -2, 1, -6),
            Size = UDim2.fromOffset(4, 2),
            BackgroundColor3 = Color3.fromRGB(60, 60, 60),
            BorderSizePixel = 0,
            ZIndex = 11,
            Parent = resizeGrip,
        })

        local grip: Frame = resizeGrip :: Frame
        grip.InputBegan:Connect(function(input: InputObject)
            if input.UserInputType == Enum.UserInputType.MouseButton1 then
                resizing = true
                resizeObject = mainBtn
                resizeStart = input.Position
                resizeOrigW = mainBtn.Size.X.Offset
            end
        end)
    end

    parentTable.content = library:Create("Frame", {
        Position = UDim2.fromOffset(0, size),
        Size = UDim2.new(1, 0, 1, -size),
        BackgroundTransparency = 1,
        Parent = mainBtn,
    }) :: Frame

    local layout = library:Create("UIListLayout", {
        SortOrder = Enum.SortOrder.LayoutOrder,
        Parent = parentTable.content,
    }) :: UIListLayout

    layout:GetPropertyChangedSignal("AbsoluteContentSize"):Connect(function()
        parentTable.content.Size = UDim2.new(1, 0, 0, layout.AbsoluteContentSize.Y)
        local targetH: number = if #parentTable.options > 0 and parentTable.open
            then layout.AbsoluteContentSize.Y + size
            else size
        parentTable.main.Size = UDim2.new(0, mainBtn.Size.X.Offset, 0, targetH)
    end)

    if not subHolder then
        library:Create("UIPadding", { Parent = parentTable.content })

        -- Drag logic
        title.InputBegan:Connect(function(input: InputObject)
            if input.UserInputType == Enum.UserInputType.MouseButton1 then
                dragObject = mainBtn
                dragging = true
                dragStart = input.Position
                startPos = mainBtn.Position
            end
        end)
        title.InputChanged:Connect(function(input: InputObject)
            if dragging and input.UserInputType == Enum.UserInputType.MouseMovement then
                dragInput = input
            end
        end)
        title.InputEnded:Connect(function(input: InputObject)
            if input.UserInputType == Enum.UserInputType.MouseButton1 then
                dragging = false
            end
        end)
    end

    -- Toggle open/close
    closeHolder.InputBegan:Connect(function(input: InputObject)
        if input.UserInputType ~= Enum.UserInputType.MouseButton1 then return end

        parentTable.open = not parentTable.open
        tween(close, TWEEN_NORMAL, {
            Rotation = if parentTable.open then 90 else 180,
            ImageColor3 = if parentTable.open then Color3.fromRGB(50, 50, 50) else Color3.fromRGB(30, 30, 30),
        })

        if subHolder then
            tween(title, TWEEN_NORMAL, {
                BackgroundColor3 = if parentTable.open then Color3.fromRGB(16, 16, 16) else Color3.fromRGB(10, 10, 10),
            })
        elseif roundLabel then
            tween(roundLabel, TWEEN_NORMAL, {
                ImageColor3 = if parentTable.open then Color3.fromRGB(10, 10, 10) else Color3.fromRGB(6, 6, 6),
            })
        end

        local targetH: number = if #parentTable.options > 0 and parentTable.open
            then layout.AbsoluteContentSize.Y + size
            else size
        tween(mainBtn, TWEEN_NORMAL, { Size = UDim2.new(0, mainBtn.Size.X.Offset, 0, targetH) })
    end)

    function parentTable:SetTitle(newTitle: string)
        title.Text = tostring(newTitle)
    end

    return parentTable
end

------------------------------ Element creators ----------------------------

-- ═══════════════════ LABEL ═══════════════════
local function createLabel(option: OptionBase, parent: any)
    local main = library:Create("TextLabel", {
        LayoutOrder = option.position,
        Size = UDim2.new(1, 0, 0, 26),
        BackgroundTransparency = 1,
        Text = " " .. option.text,
        TextSize = 17,
        Font = Enum.Font.Gotham,
        TextColor3 = Color3.fromRGB(255, 255, 255),
        TextXAlignment = Enum.TextXAlignment.Left,
        Parent = parent.content,
    })

    setmetatable(option, {
        __newindex = function(_t, i, v)
            if i == "Text" then
                main.Text = " " .. tostring(v)
            end
        end,
    })
end

-- ═══════════════════ TOGGLE ═══════════════════
local function createToggle(option: OptionBase, parent: any)
    local main = library:Create("TextLabel", {
        LayoutOrder = option.position,
        Size = UDim2.new(1, 0, 0, 31),
        BackgroundTransparency = 1,
        Text = " " .. option.text,
        TextSize = 17,
        Font = Enum.Font.Gotham,
        TextColor3 = Color3.fromRGB(255, 255, 255),
        TextXAlignment = Enum.TextXAlignment.Left,
        Parent = parent.content,
    }) :: TextLabel

    local tickboxOutline = library:Create("ImageLabel", {
        Position = UDim2.new(1, -6, 0, 4),
        Size = UDim2.new(-1, 10, 1, -10),
        SizeConstraint = Enum.SizeConstraint.RelativeYY,
        BackgroundTransparency = 1,
        Image = "rbxassetid://3570695787",
        ImageColor3 = if option.state then ACCENT else Color3.fromRGB(100, 100, 100),
        ScaleType = Enum.ScaleType.Slice,
        SliceCenter = Rect.new(100, 100, 100, 100),
        SliceScale = 0.02,
        Parent = main,
    }) :: ImageLabel

    local tickboxInner = library:Create("ImageLabel", {
        Position = UDim2.fromOffset(2, 2),
        Size = UDim2.new(1, -4, 1, -4),
        BackgroundTransparency = 1,
        Image = "rbxassetid://3570695787",
        ImageColor3 = if option.state then ACCENT else Color3.fromRGB(20, 20, 20),
        ScaleType = Enum.ScaleType.Slice,
        SliceCenter = Rect.new(100, 100, 100, 100),
        SliceScale = 0.02,
        Parent = tickboxOutline,
    }) :: ImageLabel

    local checkmarkHolder = library:Create("Frame", {
        Position = UDim2.fromOffset(4, 4),
        Size = if option.state then UDim2.new(1, -8, 1, -8) else UDim2.new(0, 0, 1, -8),
        BackgroundTransparency = 1,
        ClipsDescendants = true,
        Parent = tickboxOutline,
    }) :: Frame

    library:Create("ImageLabel", {
        Size = UDim2.fromScale(1, 1),
        SizeConstraint = Enum.SizeConstraint.RelativeYY,
        BackgroundTransparency = 1,
        Image = "rbxassetid://4919148038",
        ImageColor3 = Color3.fromRGB(20, 20, 20),
        Parent = checkmarkHolder,
    })

    local inContact = false

    main.InputBegan:Connect(function(input: InputObject)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            option:SetState(not option.state)
        end
        if input.UserInputType == Enum.UserInputType.MouseMovement then
            inContact = true
            if not option.state then
                tween(tickboxOutline, TWEEN_QUICK, { ImageColor3 = Color3.fromRGB(140, 140, 140) })
            end
        end
    end)

    main.InputEnded:Connect(function(input: InputObject)
        if input.UserInputType == Enum.UserInputType.MouseMovement then
            inContact = false
            if not option.state then
                tween(tickboxOutline, TWEEN_QUICK, { ImageColor3 = Color3.fromRGB(100, 100, 100) })
            end
        end
    end)

    function option:SetState(state: boolean)
        library.flags[self.flag] = state
        self.state = state
        tween(checkmarkHolder, TWEEN_NORMAL, { Size = if state then UDim2.new(1, -8, 1, -8) else UDim2.new(0, 0, 1, -8) })
        tween(tickboxInner, TWEEN_NORMAL, { ImageColor3 = if state then ACCENT else Color3.fromRGB(20, 20, 20) })
        tween(tickboxOutline, TWEEN_NORMAL, {
            ImageColor3 = if state then ACCENT elseif inContact then Color3.fromRGB(140, 140, 140) else Color3.fromRGB(100, 100, 100),
        })
        self.callback(state)
    end

    if option.state then
        task.delay(1, function()
            option.callback(true)
        end)
    end

    setmetatable(option, {
        __newindex = function(_t, i, v)
            if i == "Text" then
                main.Text = " " .. tostring(v)
            end
        end,
    })
end

-- ═══════════════════ BUTTON ═══════════════════
local function createButton(option: OptionBase, parent: any)
    local main = library:Create("TextLabel", {
        ZIndex = 2,
        LayoutOrder = option.position,
        Size = UDim2.new(1, 0, 0, 34),
        BackgroundTransparency = 1,
        Text = " " .. option.text,
        TextSize = 17,
        Font = Enum.Font.Gotham,
        TextColor3 = Color3.fromRGB(255, 255, 255),
        Parent = parent.content,
    }) :: TextLabel

    local roundBg = library:Create("ImageLabel", {
        AnchorPoint = Vector2.new(0.5, 0.5),
        Position = UDim2.fromScale(0.5, 0.5),
        Size = UDim2.new(1, -12, 1, -10),
        BackgroundTransparency = 1,
        Image = "rbxassetid://3570695787",
        ImageColor3 = Color3.fromRGB(40, 40, 40),
        ScaleType = Enum.ScaleType.Slice,
        SliceCenter = Rect.new(100, 100, 100, 100),
        SliceScale = 0.02,
        Parent = main,
    }) :: ImageLabel

    local inContact = false
    local clicking = false

    main.InputBegan:Connect(function(input: InputObject)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            library.flags[option.flag] = true
            clicking = true
            tween(roundBg, TWEEN_NORMAL, { ImageColor3 = ACCENT })
            option.callback()
        end
        if input.UserInputType == Enum.UserInputType.MouseMovement then
            inContact = true
            tween(roundBg, TWEEN_QUICK, { ImageColor3 = Color3.fromRGB(60, 60, 60) })
        end
    end)

    main.InputEnded:Connect(function(input: InputObject)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            clicking = false
            tween(roundBg, TWEEN_NORMAL, { ImageColor3 = if inContact then Color3.fromRGB(60, 60, 60) else Color3.fromRGB(40, 40, 40) })
        end
        if input.UserInputType == Enum.UserInputType.MouseMovement then
            inContact = false
            if not clicking then
                tween(roundBg, TWEEN_QUICK, { ImageColor3 = Color3.fromRGB(40, 40, 40) })
            end
        end
    end)
end

-- ═══════════════════ BIND ═══════════════════
local function createBind(option: OptionBase, parent: any)
    local binding = false
    local loop: RBXScriptConnection? = nil

    local keyText: string = if string.match(option.key, "Mouse")
        then string.sub(option.key, 1, 5) .. string.sub(option.key, 12, 13)
        else option.key

    local main = library:Create("TextLabel", {
        LayoutOrder = option.position,
        Size = UDim2.new(1, 0, 0, 33),
        BackgroundTransparency = 1,
        Text = " " .. option.text,
        TextSize = 17,
        Font = Enum.Font.Gotham,
        TextColor3 = Color3.fromRGB(255, 255, 255),
        TextXAlignment = Enum.TextXAlignment.Left,
        Parent = parent.content,
    }) :: TextLabel

    local textWidth = TextService:GetTextSize(keyText, 16, Enum.Font.Gotham, Vector2.new(1e9, 1e9)).X

    local roundBg = library:Create("ImageLabel", {
        Position = UDim2.new(1, -6, 0, 4),
        Size = UDim2.new(0, -(textWidth + 16), 1, -10),
        SizeConstraint = Enum.SizeConstraint.RelativeYY,
        BackgroundTransparency = 1,
        Image = "rbxassetid://3570695787",
        ImageColor3 = Color3.fromRGB(40, 40, 40),
        ScaleType = Enum.ScaleType.Slice,
        SliceCenter = Rect.new(100, 100, 100, 100),
        SliceScale = 0.02,
        Parent = main,
    }) :: ImageLabel

    local bindLabel = library:Create("TextLabel", {
        Size = UDim2.fromScale(1, 1),
        BackgroundTransparency = 1,
        Text = keyText,
        TextSize = 16,
        Font = Enum.Font.Gotham,
        TextColor3 = Color3.fromRGB(255, 255, 255),
        Parent = roundBg,
    }) :: TextLabel

    local inContact = false

    main.InputBegan:Connect(function(input: InputObject)
        if input.UserInputType == Enum.UserInputType.MouseMovement then
            inContact = true
            if not binding then
                tween(roundBg, TWEEN_QUICK, { ImageColor3 = Color3.fromRGB(60, 60, 60) })
            end
        end
    end)

    main.InputEnded:Connect(function(input: InputObject)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            binding = true
            bindLabel.Text = "..."
            tween(roundBg, TWEEN_NORMAL, { ImageColor3 = ACCENT })
        end
        if input.UserInputType == Enum.UserInputType.MouseMovement then
            inContact = false
            if not binding then
                tween(roundBg, TWEEN_QUICK, { ImageColor3 = Color3.fromRGB(40, 40, 40) })
            end
        end
    end)

    InputService.InputBegan:Connect(function(input: InputObject)
        if InputService:GetFocusedTextBox() then return end

        if (input.KeyCode.Name == option.key or input.UserInputType.Name == option.key) and not binding then
            if option.hold then
                loop = RunService.Heartbeat:Connect(function()
                    if binding then
                        option.callback(true)
                        if loop then loop:Disconnect(); loop = nil end
                    else
                        option.callback()
                    end
                end)
            else
                option.callback()
            end
        elseif binding then
            local key: (Enum.KeyCode | Enum.UserInputType)? = nil
            if not contains(BLACKLISTED_KEYS, input.KeyCode) then
                key = input.KeyCode
            end
            if key == nil and contains(WHITELISTED_MOUSE, input.UserInputType) then
                key = input.UserInputType
            end
            option:SetKey(key)
        end
    end)

    InputService.InputEnded:Connect(function(input: InputObject)
        if input.KeyCode.Name == option.key or input.UserInputType.Name == option.key then
            if loop then
                loop:Disconnect()
                loop = nil
                option.callback(true)
            end
        end
    end)

    function option:SetKey(key: any?)
        binding = false
        if loop then loop:Disconnect(); loop = nil end
        self.key = if key then (if typeof(key) == "EnumItem" then key.Name else key) else self.key
        library.flags[self.flag] = self.key
        local display: string = self.key
        if string.match(display, "Mouse") then
            display = string.sub(display, 1, 5) .. string.sub(display, 12, 13)
        end
        bindLabel.Text = display
        tween(roundBg, TWEEN_NORMAL, { ImageColor3 = if inContact then Color3.fromRGB(60, 60, 60) else Color3.fromRGB(40, 40, 40) })
        local w = TextService:GetTextSize(display, 15, Enum.Font.Gotham, Vector2.new(1e9, 1e9)).X
        roundBg.Size = UDim2.new(0, -(w + 16), 1, -10)
