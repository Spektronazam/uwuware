------------------------------ Types ------------------------------
export type Flag = string | number | boolean | Color3

export type OptionBase = {
    text: string,
    type: string,
    position: number,
    flag: string,
    [string]: any,
}

export type WindowDef = {
    title: string,
    options: { OptionBase },
    open: boolean,
    canInit: boolean,
    init: boolean,
    position: number,
    main: ImageButton?,
    content: Frame?,
    -- methods added at runtime
    [string]: any,
}

export type Library = {
    flags: { [string]: Flag },
    windows: { WindowDef },
    open: boolean,
    base: ScreenGui?,
    cursor: Frame?,
    activePopup: any?,
    -- theme
    accentColor: Color3,
    -- sizing memory for undo-on-exit
    _originalSizes: { [ImageButton]: UDim2 },
    _originalPositions: { [ImageButton]: UDim2 },
    _slideTarget: UDim2?,
    -- methods
    [string]: any,
}

