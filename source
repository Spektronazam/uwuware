        Text = holderTitle,
        TextSize = if subHolder then 16 else 17,
        Font = Enum.Font.GothamBold,
        TextColor3 = Color3.fromRGB(255, 255, 255),
        Parent = mainBtn,
    }) :: TextLabel

    local closeHolder = library:Create("Frame", {
        Position = UDim2.new(1, 0, 0, 0),
        Size = UDim2.new(-1, 0, 1, 0),
        SizeConstraint = Enum.SizeConstraint.RelativeYY,
        BackgroundTransparency = 1,
        Parent = title,
    }) :: Frame

    local close = library:Create("ImageLabel", {
        AnchorPoint = Vector2.new(0.5, 0.5),
        Position = UDim2.fromScale(0.5, 0.5),
        Size = UDim2.new(1, -size - 10, 1, -size - 10),
        Rotation = if parentTable.open then 90 else 180,
        BackgroundTransparency = 1,
        Image = "rbxassetid://4918373417",
        ImageColor3 = if parentTable.open then Color3.fromRGB(50, 50, 50) else Color3.fromRGB(30, 30, 30),
        ScaleType = Enum.ScaleType.Fit,
        Parent = closeHolder,
    }) :: ImageLabel

    -- Resize grip for top-level windows
    if not subHolder then
        local resizeGrip = library:Create("Frame", {
            Name = "ResizeGrip",
            AnchorPoint = Vector2.new(1, 1),
            Position = UDim2.new(1, 0, 1, 0),
            Size = UDim2.fromOffset(14, 14),
            BackgroundTransparency = 1,
            ZIndex = 10,
            Parent = mainBtn,
        }) :: Frame

        library:Create("Frame", {
            AnchorPoint = Vector2.new(1, 1),
            Position = UDim2.new(1, -2, 1, -2),
            Size = UDim2.fromOffset(8, 2),
            BackgroundColor3 = Color3.fromRGB(60, 60, 60),
            BorderSizePixel = 0,
            ZIndex = 11,
            Parent = resizeGrip,
        })
        library:Create("Frame", {
            AnchorPoint = Vector2.new(1, 1),
            Position = UDim2.new(1, -2, 1, -6),
            Size = UDim2.fromOffset(4, 2),
            BackgroundColor3 = Color3.fromRGB(60, 60, 60),
            BorderSizePixel = 0,
            ZIndex = 11,
            Parent = resizeGrip,
        })

        resizeGrip.InputBegan:Connect(function(input: InputObject)
            if input.UserInputType == Enum.UserInputType.MouseButton1 then
                resizing = true
                resizeObject = mainBtn
                resizeStart = input.Position
                resizeOrigW = mainBtn.Size.X.Offset
            end
        end)
    end

    parentTable.content = library:Create("Frame", {
        Position = UDim2.fromOffset(0, size),
        Size = UDim2.new(1, 0, 1, -size),
        BackgroundTransparency = 1,
        Parent = mainBtn,
    }) :: Frame

    local layout = library:Create("UIListLayout", {
        SortOrder = Enum.SortOrder.LayoutOrder,
        Parent = parentTable.content,
    }) :: UIListLayout

    layout:GetPropertyChangedSignal("AbsoluteContentSize"):Connect(function()
        parentTable.content.Size = UDim2.new(1, 0, 0, layout.AbsoluteContentSize.Y)
        local targetH: number = if #parentTable.options > 0 and parentTable.open
            then layout.AbsoluteContentSize.Y + size
            else size
        parentTable.main.Size = UDim2.new(0, mainBtn.Size.X.Offset, 0, targetH)
    end)

    if not subHolder then
        library:Create("UIPadding", { Parent = parentTable.content })

        title.InputBegan:Connect(function(input: InputObject)
            if input.UserInputType == Enum.UserInputType.MouseButton1 then
                -- Unsection on drag start if sectioned
                if library._sectionEnabled and parentTable._sectionId then
                    unsectionWindow(parentTable)
                end
                dragObject = mainBtn
                dragWindow = parentTable
                dragging = true
                dragStart = input.Position
                startPos = mainBtn.Position
            end
        end)
        title.InputChanged:Connect(function(input: InputObject)
            if dragging and input.UserInputType == Enum.UserInputType.MouseMovement then
                dragInput = input
            end
        end)
        title.InputEnded:Connect(function(input: InputObject)
            if input.UserInputType == Enum.UserInputType.MouseButton1 then
                dragging = false
                -- Check for snap
                if library._sectionEnabled and dragWindow then
                    local target, edge = getSnapTarget(dragWindow)
                    if target and edge then
                        performSnap(dragWindow, target, edge)
                    end
                    hideSnapPreview()
                end
                dragWindow = nil
            end
        end)
    end

    closeHolder.InputBegan:Connect(function(input: InputObject)
        if input.UserInputType ~= Enum.UserInputType.MouseButton1 then return end
        parentTable.open = not parentTable.open
        tween(close, T_NORMAL, {
            Rotation = if parentTable.open then 90 else 180,
            ImageColor3 = if parentTable.open then Color3.fromRGB(50, 50, 50) else Color3.fromRGB(30, 30, 30),
        })
        if subHolder then
            tween(title, T_NORMAL, {
                BackgroundColor3 = if parentTable.open then Color3.fromRGB(16, 16, 16) else Color3.fromRGB(10, 10, 10),
            })
        elseif roundLabel then
            tween(roundLabel, T_NORMAL, {
                ImageColor3 = if parentTable.open then Color3.fromRGB(10, 10, 10) else Color3.fromRGB(6, 6, 6),
            })
        end
        local targetH: number = if #parentTable.options > 0 and parentTable.open
            then layout.AbsoluteContentSize.Y + size
            else size
        tween(mainBtn, T_NORMAL, { Size = UDim2.new(0, mainBtn.Size.X.Offset, 0, targetH) })
    end)

    function parentTable:SetTitle(newTitle: string)
        title.Text = tostring(newTitle)
    end

    return parentTable
end

