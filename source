------------------------------ Executor Hooking Helpers ------------------
local function protectGui(gui: ScreenGui)
    -- Ordered by reliability. Each executor has different methods.
    local methods = {
        function()
            if (syn :: any) and (syn :: any).protect_gui then
                (syn :: any).protect_gui(gui)
                return true
            end
            return false
        end,
        function()
            if (gethui :: any) then
                gui.Parent = (gethui :: any)()
                return true
            end
            return false
        end,
        function()
            if (get_hidden_gui :: any) then
                gui.Parent = (get_hidden_gui :: any)()
                return true
            end
            return false
        end,
        function()
            -- Fluxus / some others use cloneref
            if (cloneref :: any) then
                local ref = (cloneref :: any)(CoreGui)
                gui.Parent = ref
                return true
            end
            return false
        end,
        function()
            -- Fallback: direct parent (may be detected)
            gui.Parent = CoreGui
            return true
        end,
    }

    for _, method in methods do
        local ok, result = pcall(method)
        if ok and result then
            return true
        end
    end
    return false
end

local function hookInput()
    -- Some executors need input hooking for UserInputService
    pcall(function()
        if (isrbxactive :: any) or (isgameactive :: any) then
            -- Good, we have activity check
        end
    end)
end

local function isActive(): boolean
    local ok, result = pcall(function()
        if (isrbxactive :: any) then
            return (isrbxactive :: any)()
        elseif (isgameactive :: any) then
            return (isgameactive :: any)()
        end
        return true
    end)
    return if ok then result else true
end

