------------------------------ Init with loading throbber -----------------
function library:Init()
    self.base = self.base or self:Create("ScreenGui") :: ScreenGui

    -- Try to protect the GUI
    local base: ScreenGui = self.base :: ScreenGui
    if syn and (syn :: any).protect_gui then
        (syn :: any).protect_gui(base)
    elseif (getgenv :: any)().get_hidden_gui then
        (getgenv :: any)().get_hidden_gui(base)
    elseif (getgenv :: any)().gethui then
        (getgenv :: any)().gethui(base)
    end
    base.Parent = CoreGui
    base.ResetOnSpawn = false
    base.Name = "uwuware_reborn"
    base.DisplayOrder = 999

    -- Custom cursor
    self.cursor = self.cursor or self:Create("Frame", {
        ZIndex = 100,
        AnchorPoint = Vector2.new(0, 0),
        Size = UDim2.fromOffset(5, 5),
        BackgroundColor3 = Color3.fromRGB(255, 255, 255),
        Parent = base,
    }) :: Frame

    -- Show loading throbber
    local throbber = createThrobber(base)

    -- Build all windows (invisible)
    for _, window in self.windows do
        if window.canInit and not window.init then
            window.init = true
            createOptionHolder(window.title, base, window)
            loadOptions(window)
        end
    end

    -- Let UI build for a beat, then animate in
    task.wait(0.8)

    -- Stop and fade out throbber
    throbber.destroy()
    task.wait(0.5)

    -- Slide windows in from center to the left, fading in
    local viewport: Vector2 = workspace.CurrentCamera and workspace.CurrentCamera.ViewportSize or Vector2.new(1920, 1080)
    local centerX: number = viewport.X / 2

    for _, window in self.windows do
        if window.main then
            local btn: ImageButton = window.main :: ImageButton

            -- Start at center, invisible
            local finalPos = btn.Position
            local targetX = finalPos.X.Offset
            btn.Position = UDim2.fromOffset(centerX - DEFAULT_WINDOW_W / 2, finalPos.Y.Offset)
            btn.ImageTransparency = 1

            -- Fade in + slide left
            tween(btn, TWEEN_SLIDE, {
                Position = UDim2.fromOffset(targetX, finalPos.Y.Offset),
                ImageTransparency = 0,
            })

            -- Update stored original position after slide
            library._originalPositions[btn] = UDim2.fromOffset(targetX, finalPos.Y.Offset)
            library._originalSizes[btn] = btn.Size
        end
    end

    return base
end

------------------------------ Resize to target (used for config load) ----
function library:ResizeWindows(width: number?)
    local w = math.clamp(width or DEFAULT_WINDOW_W, MIN_WINDOW_W, MAX_WINDOW_W)
    for _, window in self.windows do
        if window.main then
            local btn: ImageButton = window.main :: ImageButton
            local curH = btn.Size.Y.Offset
            tween(btn, TWEEN_SMOOTH, { Size = UDim2.fromOffset(w, curH) })
        end
    end
end

------------------------------ Close with undo animation ------------------
function library:Close()
    if typeof(self.base) ~= "Instance" then return end

    self.open = not self.open

    -- Close any active popup
    if self.activePopup then
        self.activePopup:Close()
    end

    if self.cursor then
        (self.cursor :: Frame).Visible = self.open
    end

    local viewport: Vector2 = workspace.CurrentCamera and workspace.CurrentCamera.ViewportSize or Vector2.new(1920, 1080)
    local centerX: number = viewport.X / 2

    for _, window in self.windows do
        if window.main then
            local btn: ImageButton = window.main :: ImageButton

            if self.open then
                -- RE-OPEN: appear at center, slide to original position
                btn.Visible = true
                local origPos = library._originalPositions[btn] or btn.Position
                local origSize = library._originalSizes[btn]

                -- Reset to original size first if it was resized
                if origSize then
                    tween(btn, TWEEN_NORMAL, { Size = origSize })
                end

                btn.Position = UDim2.fromOffset(centerX - btn.Size.X.Offset / 2, origPos.Y.Offset)
                btn.ImageTransparency = 1

                tween(btn, TWEEN_SLIDE, {
                    Position = origPos,
                    ImageTransparency = 0,
                })
            else
                -- CLOSE: undo resize → slide to center → fade out → hide
                local origSize = library._originalSizes[btn]

                -- Step 1: Resize back to original
                if origSize then
                    tweenWait(btn, TWEEN_NORMAL, { Size = origSize })
                end

                -- Step 2: Slide to center + fade out
                local curY = btn.Position.Y.Offset
                tween(btn, TWEEN_SLIDE, {
                    Position = UDim2.fromOffset(centerX - btn.Size.X.Offset / 2, curY),
                    ImageTransparency = 1,
                })

                task.delay(0.55, function()
                    if not library.open then
                        btn.Visible = false
                    end
                end)
            end
        end
    end
end

------------------------------ Global input handling ----------------------

-- Close popups when clicking outside
InputService.InputBegan:Connect(function(input: InputObject)
    if input.UserInputType == Enum.UserInputType.MouseButton1 and library.activePopup then
        local popup = library.activePopup
        local holder = popup.mainHolder
        if holder then
            local pos = holder.AbsolutePosition
            local size = holder.AbsoluteSize
            local mX, mY = input.Position.X, input.Position.Y
            if mX < pos.X or mY < pos.Y or mX > pos.X + size.X or mY > pos.Y + size.Y then
                popup:Close()
            end
        end
    end
end)

