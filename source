-- ═══════════ COLOR PICKER WINDOW ═══════════
local function createColorPickerWindow(option: OptionBase)
    option.mainHolder = library:Create("ImageButton", {
        ZIndex = 3,
        Size = UDim2.fromOffset(240, 180),
        BackgroundTransparency = 1,
        Image = "rbxassetid://3570695787",
        ImageTransparency = 1,
        ImageColor3 = Color3.fromRGB(30, 30, 30),
        ScaleType = Enum.ScaleType.Slice,
        SliceCenter = Rect.new(100, 100, 100, 100),
        SliceScale = 0.02,
        AutoButtonColor = false,
        Parent = library.base,
    }) :: ImageButton

    local hue, sat, val = Color3.toHSV(option.color)
    hue = if hue == 0 then 1 else hue
    sat += 0.005; val -= 0.005

    local editingHue = false
    local editingSatVal = false
    local currentColor: Color3 = option.color
    local previousColors: { Color3 } = { option.color }
    local originalColor: Color3 = option.color
    local rainbowEnabled = false
    local rainbowLoop: RBXScriptConnection? = nil

    function option:updateVisuals(clr: Color3)
        currentColor = clr
        self.visualize2.ImageColor3 = clr
        hue, sat, val = Color3.toHSV(clr)
        hue = if hue == 0 then 1 else hue
        self.satval.BackgroundColor3 = Color3.fromHSV(hue, 1, 1)
        self.hueSlider.Position = UDim2.new(1 - hue, 0, 0, 0)
        self.satvalSlider.Position = UDim2.new(sat, 0, 1 - val, 0)
    end

    option.hue = library:Create("ImageLabel", {
        ZIndex = 3, AnchorPoint = Vector2.new(0, 1),
        Position = UDim2.new(0, 8, 1, -8),
        Size = UDim2.new(1, -100, 0, 22),
        BackgroundTransparency = 1,
        Image = "rbxassetid://3570695787",
        ImageTransparency = 1,
        ScaleType = Enum.ScaleType.Slice,
        SliceCenter = Rect.new(100, 100, 100, 100),
        SliceScale = 0.02,
        Parent = option.mainHolder,
    }) :: ImageLabel

    library:Create("UIGradient", {
        Color = ColorSequence.new({
            ColorSequenceKeypoint.new(0, Color3.fromRGB(255, 0, 0)),
            ColorSequenceKeypoint.new(0.157, Color3.fromRGB(255, 0, 255)),
            ColorSequenceKeypoint.new(0.323, Color3.fromRGB(0, 0, 255)),
            ColorSequenceKeypoint.new(0.488, Color3.fromRGB(0, 255, 255)),
            ColorSequenceKeypoint.new(0.66, Color3.fromRGB(0, 255, 0)),
            ColorSequenceKeypoint.new(0.817, Color3.fromRGB(255, 255, 0)),
            ColorSequenceKeypoint.new(1, Color3.fromRGB(255, 0, 0)),
        }),
        Parent = option.hue,
    })

    option.hueSlider = library:Create("Frame", {
        ZIndex = 3, Position = UDim2.new(1 - hue, 0, 0, 0),
        Size = UDim2.new(0, 2, 1, 0),
        BackgroundTransparency = 1,
        BackgroundColor3 = Color3.fromRGB(30, 30, 30),
        BorderColor3 = Color3.fromRGB(255, 255, 255),
        Parent = option.hue,
    }) :: Frame

    option.hue.InputBegan:Connect(function(input: InputObject)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            editingHue = true
            local X = math.clamp((input.Position.X - option.hue.AbsolutePosition.X) / option.hue.AbsoluteSize.X, 0, 0.995)
            option:updateVisuals(Color3.fromHSV(1 - X, sat, val))
        end
    end)

    InputService.InputChanged:Connect(function(input: InputObject)
        if input.UserInputType == Enum.UserInputType.MouseMovement and editingHue then
            local X = math.clamp((input.Position.X - option.hue.AbsolutePosition.X) / option.hue.AbsoluteSize.X, 0, 0.995)
            option:updateVisuals(Color3.fromHSV(1 - X, sat, val))
        end
    end)

    option.hue.InputEnded:Connect(function(input: InputObject)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then editingHue = false end
    end)

    option.satval = library:Create("ImageLabel", {
        ZIndex = 3, Position = UDim2.fromOffset(8, 8),
        Size = UDim2.new(1, -100, 1, -42),
        BackgroundTransparency = 1,
        BackgroundColor3 = Color3.fromHSV(hue, 1, 1),
        BorderSizePixel = 0,
        Image = "rbxassetid://4155801252",
        ImageTransparency = 1,
        ClipsDescendants = true,
        Parent = option.mainHolder,
    }) :: ImageLabel

    option.satvalSlider = library:Create("Frame", {
        ZIndex = 3, AnchorPoint = Vector2.new(0.5, 0.5),
        Position = UDim2.new(sat, 0, 1 - val, 0),
        Size = UDim2.fromOffset(4, 4),
        Rotation = 45,
        BackgroundTransparency = 1,
        BackgroundColor3 = Color3.fromRGB(255, 255, 255),
        Parent = option.satval,
    }) :: Frame

    option.satval.InputBegan:Connect(function(input: InputObject)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            editingSatVal = true
            local X = math.clamp((input.Position.X - option.satval.AbsolutePosition.X) / option.satval.AbsoluteSize.X, 0.005, 1)
            local Y = math.clamp((input.Position.Y - option.satval.AbsolutePosition.Y) / option.satval.AbsoluteSize.Y, 0, 0.995)
            option:updateVisuals(Color3.fromHSV(hue, X, 1 - Y))
        end
    end)

    InputService.InputChanged:Connect(function(input: InputObject)
        if input.UserInputType == Enum.UserInputType.MouseMovement and editingSatVal then
            local X = math.clamp((input.Position.X - option.satval.AbsolutePosition.X) / option.satval.AbsoluteSize.X, 0.005, 1)
            local Y = math.clamp((input.Position.Y - option.satval.AbsolutePosition.Y) / option.satval.AbsoluteSize.Y, 0, 0.995)
            option:updateVisuals(Color3.fromHSV(hue, X, 1 - Y))
        end
    end)

    option.satval.InputEnded:Connect(function(input: InputObject)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then editingSatVal = false end
    end)

    option.visualize2 = library:Create("ImageLabel", {
        ZIndex = 3, Position = UDim2.new(1, -8, 0, 8),
        Size = UDim2.fromOffset(-80, 80),
        BackgroundTransparency = 1,
        Image = "rbxassetid://3570695787",
        ImageColor3 = currentColor,
        ScaleType = Enum.ScaleType.Slice,
        SliceCenter = Rect.new(100, 100, 100, 100),
        SliceScale = 0.02,
        Parent = option.mainHolder,
    }) :: ImageLabel

    local function makeActionBtn(yOff: number, label: string): (ImageLabel, TextLabel)
        local bg = library:Create("ImageLabel", {
            ZIndex = 3, Position = UDim2.new(1, -8, 0, yOff),
            Size = UDim2.fromOffset(-80, 18),
            BackgroundTransparency = 1,
            Image = "rbxassetid://3570695787",
            ImageTransparency = 1,
            ImageColor3 = Color3.fromRGB(20, 20, 20),
            ScaleType = Enum.ScaleType.Slice,
            SliceCenter = Rect.new(100, 100, 100, 100),
            SliceScale = 0.02,
            Parent = option.mainHolder,
        }) :: ImageLabel

        local txt = library:Create("TextLabel", {
            ZIndex = 3, Size = UDim2.fromScale(1, 1),
            BackgroundTransparency = 1,
            Text = label, TextTransparency = 1,
            Font = Enum.Font.Code, TextSize = 15,
            TextColor3 = Color3.fromRGB(255, 255, 255),
            Parent = bg,
        }) :: TextLabel

        bg.InputBegan:Connect(function(inp: InputObject)
            if inp.UserInputType == Enum.UserInputType.MouseMovement and not dragging then
                tween(bg, T_NORMAL, { ImageColor3 = Color3.fromRGB(10, 10, 10) })
            end
        end)
        bg.InputEnded:Connect(function(inp: InputObject)
            if inp.UserInputType == Enum.UserInputType.MouseMovement and not dragging then
                tween(bg, T_NORMAL, { ImageColor3 = Color3.fromRGB(20, 20, 20) })
            end
        end)
        return bg, txt
    end

    local resetBtn, _ = makeActionBtn(92, "Reset")
    local undoBtn, _ = makeActionBtn(112, "Undo")
    local setBtn, _ = makeActionBtn(132, "Set")
    local rainbowBtn, rainbowTxt = makeActionBtn(152, "Rainbow")

    resetBtn.InputBegan:Connect(function(inp: InputObject)
        if inp.UserInputType == Enum.UserInputType.MouseButton1 and not rainbowEnabled then
            previousColors = { originalColor }
            option:SetColor(originalColor)
        end
    end)

    undoBtn.InputBegan:Connect(function(inp: InputObject)
        if inp.UserInputType == Enum.UserInputType.MouseButton1 and not rainbowEnabled then
            local num = if #previousColors == 1 then 0 else 1
            option:SetColor(previousColors[#previousColors - num])
            if #previousColors ~= 1 then table.remove(previousColors, #previousColors) end
        end
    end)

    setBtn.InputBegan:Connect(function(inp: InputObject)
        if inp.UserInputType == Enum.UserInputType.MouseButton1 and not rainbowEnabled then
            table.insert(previousColors, currentColor)
            option:SetColor(currentColor)
        end
    end)

    rainbowBtn.InputBegan:Connect(function(inp: InputObject)
        if inp.UserInputType == Enum.UserInputType.MouseButton1 then
            rainbowEnabled = not rainbowEnabled
            if rainbowEnabled then
                rainbowLoop = RunService.Heartbeat:Connect(function()
                    option:SetColor(chromaColor)
                    rainbowTxt.TextColor3 = chromaColor
                end)
            else
                if rainbowLoop then rainbowLoop:Disconnect() end
                option:SetColor(previousColors[#previousColors])
                rainbowTxt.TextColor3 = Color3.fromRGB(255, 255, 255)
            end
        end
    end)

    return option
end

-- ═══════════ COLOR PICKER (inline) ═══════════
local function createColor(option: OptionBase, parent: any, _holder: any?)
    option.main = library:Create("TextLabel", {
        LayoutOrder = option.position,
        Size = UDim2.new(1, 0, 0, 31),
        BackgroundTransparency = 1,
        Text = " " .. option.text,
        TextSize = 17,
        Font = Enum.Font.Gotham,
        TextColor3 = Color3.fromRGB(255, 255, 255),
        TextXAlignment = Enum.TextXAlignment.Left,
        Parent = parent.content,
    }) :: TextLabel

    local colorBoxOutline = library:Create("ImageLabel", {
        Position = UDim2.new(1, -6, 0, 4),
        Size = UDim2.new(-1, 10, 1, -10),
        SizeConstraint = Enum.SizeConstraint.RelativeYY,
        BackgroundTransparency = 1,
        Image = "rbxassetid://3570695787",
        ImageColor3 = Color3.fromRGB(100, 100, 100),
        ScaleType = Enum.ScaleType.Slice,
        SliceCenter = Rect.new(100, 100, 100, 100),
        SliceScale = 0.02,
        Parent = option.main,
    }) :: ImageLabel

    option.visualize = library:Create("ImageLabel", {
        Position = UDim2.fromOffset(2, 2),
        Size = UDim2.new(1, -4, 1, -4),
        BackgroundTransparency = 1,
        Image = "rbxassetid://3570695787",
        ImageColor3 = option.color,
        ScaleType = Enum.ScaleType.Slice,
        SliceCenter = Rect.new(100, 100, 100, 100),
        SliceScale = 0.02,
        Parent = colorBoxOutline,
    }) :: ImageLabel

    local inContact = false

    option.main.InputBegan:Connect(function(input: InputObject)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            if not option.mainHolder then createColorPickerWindow(option) end
            if library.activePopup then library.activePopup:Close() end
            local pos = option.main.AbsolutePosition
            option.mainHolder.Position = UDim2.fromOffset(pos.X - 5, pos.Y - 10)
            option.open = true
            option.mainHolder.Visible = true
            library.activePopup = option

            -- Synchronized fade in of the color picker
            local cache = cacheTransparency(option.mainHolder)
            -- Set the picker background visible first
            tween(option.mainHolder, T_SMOOTH, { ImageTransparency = 0, Position = UDim2.fromOffset(pos.X - 5, pos.Y + 1) })
            tween(option.satval, T_SMOOTH, { BackgroundTransparency = 0 })
            -- Fade in all children in sync
            fadeIn(option.mainHolder, T_SMOOTH, cache)
        end
        if input.UserInputType == Enum.UserInputType.MouseMovement then
            inContact = true
            if not option.open then tween(colorBoxOutline, T_QUICK, { ImageColor3 = Color3.fromRGB(140, 140, 140) }) end
        end
    end)

    option.main.InputEnded:Connect(function(input: InputObject)
        if input.UserInputType == Enum.UserInputType.MouseMovement then
            inContact = false
            if not option.open then tween(colorBoxOutline, T_QUICK, { ImageColor3 = Color3.fromRGB(100, 100, 100) }) end
        end
    end)

    function option:SetColor(newColor: Color3)
        if self.mainHolder then self:updateVisuals(newColor) end
        self.visualize.ImageColor3 = newColor
        library.flags[self.flag] = newColor
        self.color = newColor
        self.callback(newColor)
    end

    function option:Close()
        library.activePopup = nil
        self.open = false
        local pos = self.main.AbsolutePosition

        -- Synchronized fade out
        local cache = cacheTransparency(self.mainHolder)
        fadeOut(self.mainHolder, T_SMOOTH, cache)
        tween(self.mainHolder, T_SMOOTH, { ImageTransparency = 1, Position = UDim2.fromOffset(pos.X - 5, pos.Y - 10) })
        tween(self.satval, T_SMOOTH, { BackgroundTransparency = 1 })

        task.delay(0.4, function()
            if not self.open then self.mainHolder.Visible = false end
        end)
    end
end

------------------------------ Load options recursively -------------------
local function loadOptions(optionHolder: any, holder: any?)
    for _, opt in optionHolder.options do
        local t = opt.type
        if t == "label" then createLabel(opt, optionHolder)
        elseif t == "toggle" then createToggle(opt, optionHolder)
        elseif t == "button" then createButton(opt, optionHolder)
        elseif t == "list" then createList(opt, optionHolder, holder)
        elseif t == "box" then createBox(opt, optionHolder)
        elseif t == "bind" then createBind(opt, optionHolder)
        elseif t == "slider" then createSlider(opt, optionHolder)
        elseif t == "color" then createColor(opt, optionHolder, holder)
        elseif t == "folder" then opt:init()
        end
    end
end

------------------------------ Register option methods --------------------
local function addMethods(parent: any)
    function parent:AddLabel(option: { [string]: any }?)
        local o: any = if typeof(option) == "table" then option else {}
        o.text = tostring(o.text); o.type = "label"; o.position = #self.options
        table.insert(self.options, o); return o
    end

    function parent:AddToggle(option: { [string]: any }?)
        local o: any = if typeof(option) == "table" then option else {}
        o.text = tostring(o.text)
        o.state = if typeof(o.state) == "boolean" then o.state else false
        o.callback = if typeof(o.callback) == "function" then o.callback else function() end
        o.type = "toggle"; o.position = #self.options
        o.flag = o.flag or o.text; library.flags[o.flag] = o.state
        table.insert(self.options, o); return o
    end

    function parent:AddButton(option: { [string]: any }?)
        local o: any = if typeof(option) == "table" then option else {}
        o.text = tostring(o.text)
        o.callback = if typeof(o.callback) == "function" then o.callback else function() end
        o.type = "button"; o.position = #self.options
        o.flag = o.flag or o.text
        table.insert(self.options, o); return o
    end

    function parent:AddBind(option: { [string]: any }?)
        local o: any = if typeof(option) == "table" then option else {}
        o.text = tostring(o.text)
        o.key = (if o.key and typeof(o.key) == "EnumItem" then o.key.Name else o.key) or "F"
        o.hold = if typeof(o.hold) == "boolean" then o.hold else false
        o.callback = if typeof(o.callback) == "function" then o.callback else function() end
        o.type = "bind"; o.position = #self.options
        o.flag = o.flag or o.text; library.flags[o.flag] = o.key
        table.insert(self.options, o); return o
    end

    function parent:AddSlider(option: { [string]: any }?)
        local o: any = if typeof(option) == "table" then option else {}
        o.text = tostring(o.text)
        o.min = if typeof(o.min) == "number" then o.min else 0
        o.max = if typeof(o.max) == "number" then o.max else 0
        o.value = math.clamp(if typeof(o.value) == "number" then o.value else o.min, o.min, o.max)
        o.callback = if typeof(o.callback) == "function" then o.callback else function() end
        o.float = if typeof(o.float) == "number" then o.float else 1
        o.type = "slider"; o.position = #self.options
        o.flag = o.flag or o.text; library.flags[o.flag] = o.value
        table.insert(self.options, o); return o
    end

    function parent:AddList(option: { [string]: any }?)
        local o: any = if typeof(option) == "table" then option else {}
        o.text = tostring(o.text)
        o.values = if typeof(o.values) == "table" then o.values else {}
        o.value = tostring(o.value or o.values[1] or "")
        o.callback = if typeof(o.callback) == "function" then o.callback else function() end
        o.open = false; o.type = "list"; o.position = #self.options
        o.flag = o.flag or o.text; library.flags[o.flag] = o.value
        table.insert(self.options, o); return o
    end

    function parent:AddBox(option: { [string]: any }?)
        local o: any = if typeof(option) == "table" then option else {}
        o.text = tostring(o.text)
        o.value = tostring(o.value or "")
        o.callback = if typeof(o.callback) == "function" then o.callback else function() end
        o.type = "box"; o.position = #self.options
        o.flag = o.flag or o.text; library.flags[o.flag] = o.value
        table.insert(self.options, o); return o
    end

    function parent:AddColor(option: { [string]: any }?)
        local o: any = if typeof(option) == "table" then option else {}
        o.text = tostring(o.text)
        o.color = if typeof(o.color) == "table"
            then Color3.new(tonumber(o.color[1]) or 1, tonumber(o.color[2]) or 1, tonumber(o.color[3]) or 1)
            else (o.color or Color3.new(1, 1, 1))
        o.callback = if typeof(o.callback) == "function" then o.callback else function() end
        o.open = false; o.type = "color"; o.position = #self.options
        o.flag = o.flag or o.text; library.flags[o.flag] = o.color
        table.insert(self.options, o); return o
    end

    function parent:AddFolder(title: string)
        local o: any = {}
        o.title = tostring(title); o.options = {}; o.open = false
        o.type = "folder"; o.position = #self.options
        table.insert(self.options, o)
        addMethods(o)

        function o:init()
            createOptionHolder(self.title, parent.content, self, true)
            loadOptions(self, parent)
        end
        return o
    end
end

------------------------------ Window creation ----------------------------
function library:CreateWindow(title: string)
    local window: any = {
        title = tostring(title), options = {}, open = true,
        canInit = true, init = false, position = #self.windows,
    }
    addMethods(window)
    table.insert(self.windows, window)
    return window
end

------------------------------ Init ----------------------------------------
function library:Init()
    self.base = self.base or self:Create("ScreenGui") :: ScreenGui
    local base: ScreenGui = self.base :: ScreenGui

    -- Protect GUI for executor environment
    protectGui(base)
    hookInput()

    -- If protectGui didn't parent it (syn.protect_gui doesn't), parent to CoreGui
    if not base.Parent then
        base.Parent = CoreGui
    end

    base.ResetOnSpawn = false
    base.Name = "uwuware_reborn"
    base.DisplayOrder = 999

    -- Cursor
    self.cursor = self.cursor or self:Create("Frame", {
        ZIndex = 100, AnchorPoint = Vector2.new(0, 0),
        Size = UDim2.fromOffset(5, 5),
        BackgroundColor3 = Color3.fromRGB(255, 255, 255),
        Parent = base,
    }) :: Frame

    -- Section preview indicator (created early, used during drag)
    self._sectionPreview = createSectionPreview(base)

    -- Loading throbber
    local throbber = createThrobber(base)

    -- Build all windows (invisible at this point)
    for _, window in self.windows do
        if window.canInit and not window.init then
            window.init = true
            createOptionHolder(window.title, base, window)
            loadOptions(window)
        end
    end

    -- Cache transparency values for every window BEFORE we ever touch them
    for _, window in self.windows do
        if window.main then
            library._transparencyCache[window.main] = cacheTransparency(window.main)
        end
    end

    task.wait(0.8)

    -- Kill throbber
    throbber.destroy()
    task.wait(0.55)

    -- Slide windows in from center, synchronized fade
    local viewport: Vector2 = if workspace.CurrentCamera then workspace.CurrentCamera.ViewportSize else Vector2.new(1920, 1080)
    local centerX: number = viewport.X / 2

    for _, window in self.windows do
        if window.main then
            local btn: ImageButton = window.main :: ImageButton
            local finalPos = btn.Position
            local targetX = finalPos.X.Offset

            -- Start at center, fully transparent
            btn.Position = UDim2.fromOffset(centerX - DEFAULT_WINDOW_W / 2, finalPos.Y.Offset)

            -- Set everything invisible
            for inst, props in (library._transparencyCache[btn] or {}) do
                for prop, _ in props do
                    pcall(function() (inst :: any)[prop] = 1 end)
                end
            end

            -- Slide
            tween(btn, T_SLIDE, { Position = UDim2.fromOffset(targetX, finalPos.Y.Offset) })

            -- Synchronized fade in of ALL children
            fadeIn(btn, T_FADE_SLOW, library._transparencyCache[btn])

            library._originalPositions[btn] = UDim2.fromOffset(targetX, finalPos.Y.Offset)
            library._originalSizes[btn] = btn.Size
        end
    end

    return base
end

------------------------------ Sectioning toggle --------------------------
function library:SetSectioning(enabled: boolean)
    self._sectionEnabled = enabled

    if enabled then
        if not self._sectionOutline and self.base then
            self._sectionOutline = createSectionOutline(self.base :: ScreenGui)
        end
        if self._sectionOutline then
            self._sectionOutline.Visible = true
        end
    else
        if self._sectionOutline then
            -- Fade out outline
            for _, child in self._sectionOutline:GetChildren() do
                if child:IsA("Frame") then
                    tween(child, T_FADE, { BackgroundTransparency = 1 })
                end
            end
            task.delay(0.4, function()
                if self._sectionOutline and not self._sectionEnabled then
                    self._sectionOutline.Visible = false
                end
            end)
        end
    end
end

------------------------------ Resize all windows -------------------------
function library:ResizeWindows(width: number?)
    local w = math.clamp(width or DEFAULT_WINDOW_W, MIN_WINDOW_W, MAX_WINDOW_W)
    for _, window in self.windows do
        if window.main then
            local btn: ImageButton = window.main :: ImageButton
            tween(btn, T_SMOOTH, { Size = UDim2.fromOffset(w, btn.Size.Y.Offset) })
        end
    end
end

------------------------------ Close with synced fade ---------------------
function library:Close()
    if typeof(self.base) ~= "Instance" then return end
    self.open = not self.open

    if self.activePopup then self.activePopup:Close() end
    if self.cursor then (self.cursor :: Frame).Visible = self.open end

    -- Hide section outline during close
    if self._sectionOutline then
        self._sectionOutline.Visible = self.open and self._sectionEnabled
    end

    local viewport: Vector2 = if workspace.CurrentCamera then workspace.CurrentCamera.ViewportSize else Vector2.new(1920, 1080)
    local centerX: number = viewport.X / 2

    for _, window in self.windows do
        if window.main then
            local btn: ImageButton = window.main :: ImageButton

            if self.open then
                -- ═══ REOPEN ═══
                btn.Visible = true
                local origPos = library._originalPositions[btn] or btn.Position
                local origSize = library._originalSizes[btn]

                -- Resize back first
                if origSize then
                    btn.Size = origSize
                end

                -- Position at center, invisible
                btn.Position = UDim2.fromOffset(centerX - btn.Size.X.Offset / 2, origPos.Y.Offset)

                -- Set everything invisible
                for inst, props in (library._transparencyCache[btn] or {}) do
                    for prop, _ in props do
                        pcall(function() (inst :: any)[prop] = 1 end)
                    end
                end

                -- Slide + synchronized fade in
                tween(btn, T_SLIDE, { Position = origPos })
                fadeIn(btn, T_FADE, library._transparencyCache[btn])
            else
                -- ═══ CLOSE ═══
                -- Step 1: resize back to original if needed
                local origSize = library._originalSizes[btn]
                if origSize and (btn.Size.X.Offset ~= origSize.X.Offset) then
                    tweenAwait(btn, T_NORMAL, { Size = origSize })
                end

                -- Step 2: synchronized fade out + slide to center
                local curY = btn.Position.Y.Offset
                local cache = cacheTransparency(btn)
                library._transparencyCache[btn] = cache

                -- Fire fade and slide simultaneously
                fadeOut(btn, T_FADE, cache)
                tween(btn, T_SLIDE, {
                    Position = UDim2.fromOffset(centerX - btn.Size.X.Offset / 2, curY),
                })

                task.delay(0.6, function()
                    if not library.open then btn.Visible = false end
                end)
            end
        end
    end
end

------------------------------ Global input --------------------------------

-- Close popups on outside click
InputService.InputBegan:Connect(function(input: InputObject)
    if not isActive() then return end
    if input.UserInputType == Enum.UserInputType.MouseButton1 and library.activePopup then
        local popup = library.activePopup
        local holder = popup.mainHolder
        if holder then
            local pos = holder.AbsolutePosition
            local size = holder.AbsoluteSize
            local mX, mY = input.Position.X, input.Position.Y
            if mX < pos.X or mY < pos.Y or mX > pos.X + size.X or mY > pos.Y + size.Y then
                popup:Close()
            end
        end
    end
end)

-- Cursor + drag + resize + section preview
InputService.InputChanged:Connect(function(input: InputObject)
    if not isActive() then return end

    -- Cursor
    if input.UserInputType == Enum.UserInputType.MouseMovement and library.cursor then
        local mouse = InputService:GetMouseLocation() + Vector2.new(0, -36)
        ;(library.cursor :: Frame).Position = UDim2.fromOffset(mouse.X - 2, mouse.Y - 2)
    end

    -- Drag
    if input == dragInput and dragging then
        updateDrag(input)

        -- Section snap preview while dragging
        if library._sectionEnabled and dragWindow then
            local target, edge = getSnapTarget(dragWindow)
            if target and edge then
                showSnapPreview(target, edge)
            else
                hideSnapPreview()
            end
        end
    end

    -- Resize
    if input.UserInputType == Enum.UserInputType.MouseMovement and resizing and resizeObject and resizeStart then
        local delta = input.Position.X - resizeStart.X
        local newW = math.clamp(resizeOrigW + delta, MIN_WINDOW_W, MAX_WINDOW_W)
        resizeObject.Size = UDim2.fromOffset(newW, resizeObject.Size.Y.Offset)
    end
end)

-- End resize / end drag
InputService.InputEnded:Connect(function(input: InputObject)
    if input.UserInputType == Enum.UserInputType.MouseButton1 then
        if resizing then
            resizing = false
            resizeObject = nil
        end
    end
end)

return library
