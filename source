local function createList(option: OptionBase, parent: any, _holder: any?)
    local valueCount = 0

    local main = library:Create("Frame", {
        LayoutOrder = option.position,
        Size = UDim2.new(1, 0, 0, 52),
        BackgroundTransparency = 1,
        Parent = parent.content,
    }) :: Frame

    local roundBg = library:Create("ImageLabel", {
        Position = UDim2.fromOffset(6, 4),
        Size = UDim2.new(1, -12, 1, -10),
        BackgroundTransparency = 1,
        Image = "rbxassetid://3570695787",
        ImageColor3 = Color3.fromRGB(40, 40, 40),
        ScaleType = Enum.ScaleType.Slice,
        SliceCenter = Rect.new(100, 100, 100, 100),
        SliceScale = 0.02,
        Parent = main,
    }) :: ImageLabel

    library:Create("TextLabel", {
        Position = UDim2.fromOffset(12, 8),
        Size = UDim2.new(1, -24, 0, 14),
        BackgroundTransparency = 1,
        Text = option.text,
        TextSize = 14,
        Font = Enum.Font.GothamBold,
        TextColor3 = Color3.fromRGB(140, 140, 140),
        TextXAlignment = Enum.TextXAlignment.Left,
        Parent = main,
    })

    local listLabel = library:Create("TextLabel", {
        Position = UDim2.fromOffset(12, 20),
        Size = UDim2.new(1, -24, 0, 24),
        BackgroundTransparency = 1,
        Text = option.value,
        TextSize = 18,
        Font = Enum.Font.Gotham,
        TextColor3 = Color3.fromRGB(255, 255, 255),
        TextXAlignment = Enum.TextXAlignment.Left,
        Parent = main,
    }) :: TextLabel

    library:Create("ImageLabel", {
        Position = UDim2.new(1, -16, 0, 16),
        Size = UDim2.new(-1, 32, 1, -32),
        SizeConstraint = Enum.SizeConstraint.RelativeYY,
        Rotation = 90,
        BackgroundTransparency = 1,
        Image = "rbxassetid://4918373417",
        ImageColor3 = Color3.fromRGB(140, 140, 140),
        ScaleType = Enum.ScaleType.Fit,
        Parent = roundBg,
    })

    option.mainHolder = library:Create("ImageButton", {
        ZIndex = 3,
        Size = UDim2.fromOffset(240, 52),
        BackgroundTransparency = 1,
        Image = "rbxassetid://3570695787",
        ImageTransparency = 1,
        ImageColor3 = Color3.fromRGB(30, 30, 30),
        ScaleType = Enum.ScaleType.Slice,
        SliceCenter = Rect.new(100, 100, 100, 100),
        SliceScale = 0.02,
        AutoButtonColor = false,
        Visible = false,
        Parent = library.base,
    }) :: ImageButton

    local content = library:Create("ScrollingFrame", {
        ZIndex = 3,
        Size = UDim2.fromScale(1, 1),
        BackgroundTransparency = 1,
        BorderSizePixel = 0,
        ScrollBarImageColor3 = Color3.new(),
        ScrollBarThickness = 0,
        ScrollingDirection = Enum.ScrollingDirection.Y,
        Parent = option.mainHolder,
    }) :: ScrollingFrame

    library:Create("UIPadding", {
        PaddingTop = UDim.new(0, 6),
        Parent = content,
    })

    local layout = library:Create("UIListLayout", {
        Parent = content,
    }) :: UIListLayout

    layout:GetPropertyChangedSignal("AbsoluteContentSize"):Connect(function()
        local h = if valueCount > 4 then (4 * 40) else layout.AbsoluteContentSize.Y
        option.mainHolder.Size = UDim2.fromOffset(240, h + 12)
        content.CanvasSize = UDim2.fromOffset(0, layout.AbsoluteContentSize.Y + 12)
    end)

    local inContact = false

    roundBg.InputBegan:Connect(function(input: InputObject)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            if library.activePopup then library.activePopup:Close() end
            local pos = main.AbsolutePosition
            option.mainHolder.Position = UDim2.fromOffset(pos.X - 5, pos.Y - 10)
            option.open = true
            option.mainHolder.Visible = true
            library.activePopup = option
            content.ScrollBarThickness = 6
            tween(option.mainHolder, TWEEN_SMOOTH, { ImageTransparency = 0, Position = UDim2.fromOffset(pos.X - 5, pos.Y - 4) })
            tween(option.mainHolder, TweenInfo.new(0.4, Enum.EasingStyle.Quad, Enum.EasingDirection.Out, 0, false, 0.1), { Position = UDim2.fromOffset(pos.X - 5, pos.Y + 1) })
            for _, label in content:GetChildren() do
                if label:IsA("TextLabel") then
                    tween(label, TWEEN_SMOOTH, { BackgroundTransparency = 0, TextTransparency = 0 })
                end
            end
        end
        if input.UserInputType == Enum.UserInputType.MouseMovement then
            inContact = true
            if not option.open then
                tween(roundBg, TWEEN_QUICK, { ImageColor3 = Color3.fromRGB(60, 60, 60) })
            end
        end
    end)

    roundBg.InputEnded:Connect(function(input: InputObject)
        if input.UserInputType == Enum.UserInputType.MouseMovement then
            inContact = false
            if not option.open then
                tween(roundBg, TWEEN_QUICK, { ImageColor3 = Color3.fromRGB(40, 40, 40) })
            end
        end
    end)

    function option:AddValue(value: string)
        valueCount += 1
        local label = library:Create("TextLabel", {
            ZIndex = 3,
            Size = UDim2.new(1, 0, 0, 40),
            BackgroundColor3 = Color3.fromRGB(30, 30, 30),
            BorderSizePixel = 0,
            Text = "    " .. value,
            TextSize = 14,
            TextTransparency = if self.open then 0 else 1,
            Font = Enum.Font.Gotham,
            TextColor3 = Color3.fromRGB(255, 255, 255),
            TextXAlignment = Enum.TextXAlignment.Left,
            Parent = content,
        }) :: TextLabel

        local labelContact = false
        local clicking = false

        label.InputBegan:Connect(function(inp: InputObject)
            if inp.UserInputType == Enum.UserInputType.MouseButton1 then
                clicking = true
                tween(label, TWEEN_NORMAL, { BackgroundColor3 = Color3.fromRGB(10, 10, 10) })
                self:SetValue(value)
            end
            if inp.UserInputType == Enum.UserInputType.MouseMovement then
                labelContact = true
                if not clicking then
                    tween(label, TWEEN_QUICK, { BackgroundColor3 = Color3.fromRGB(20, 20, 20) })
                end
            end
        end)

        label.InputEnded:Connect(function(inp: InputObject)
            if inp.UserInputType == Enum.UserInputType.MouseButton1 then
                clicking = false
                tween(label, TWEEN_NORMAL, { BackgroundColor3 = if labelContact then Color3.fromRGB(20, 20, 20) else Color3.fromRGB(30, 30, 30) })
            end
            if inp.UserInputType == Enum.UserInputType.MouseMovement then
                labelContact = false
                if not clicking then
                    tween(label, TWEEN_QUICK, { BackgroundColor3 = Color3.fromRGB(30, 30, 30) })
                end
            end
        end)
    end

    if not table.find(option.values, option.value) then
        option:AddValue(option.value)
    end
    for _, v in option.values do
        option:AddValue(tostring(v))
    end

    function option:RemoveValue(value: string)
        for _, label in content:GetChildren() do
            if label:IsA("TextLabel") and label.Text == "    " .. value then
                label:Destroy()
                valueCount -= 1
                break
            end
        end
        if self.value == value then
            self:SetValue("")
        end
    end

    function option:SetValue(value: string)
        library.flags[self.flag] = tostring(value)
        self.value = tostring(value)
        listLabel.Text = self.value
        self.callback(value)
    end

    function option:Close()
        library.activePopup = nil
        self.open = false
        content.ScrollBarThickness = 0
        local pos = main.AbsolutePosition
        tween(roundBg, TWEEN_NORMAL, { ImageColor3 = if inContact then Color3.fromRGB(60, 60, 60) else Color3.fromRGB(40, 40, 40) })
        tween(self.mainHolder, TWEEN_SMOOTH, { ImageTransparency = 1, Position = UDim2.fromOffset(pos.X - 5, pos.Y - 10) })
        for _, label in content:GetChildren() do
            if label:IsA("TextLabel") then
                tween(label, TWEEN_SMOOTH, { BackgroundTransparency = 1, TextTransparency = 1 })
            end
        end
        task.delay(0.3, function()
            if not self.open then
                self.mainHolder.Visible = false
            end
        end)
    end

    return option
end

