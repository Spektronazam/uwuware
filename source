    }) :: ImageButton

    local content = library:Create("ScrollingFrame", {
        ZIndex = 3,
        Size = UDim2.fromScale(1, 1),
        BackgroundTransparency = 1,
        BorderSizePixel = 0,
        ScrollBarImageColor3 = Color3.new(),
        ScrollBarThickness = 0,
        ScrollingDirection = Enum.ScrollingDirection.Y,
        Parent = option.mainHolder,
    }) :: ScrollingFrame

    library:Create("UIPadding", { PaddingTop = UDim.new(0, 6), Parent = content })

    local layout = library:Create("UIListLayout", { Parent = content }) :: UIListLayout

    layout:GetPropertyChangedSignal("AbsoluteContentSize"):Connect(function()
        local h = if valueCount > 4 then (4 * 40) else layout.AbsoluteContentSize.Y
        option.mainHolder.Size = UDim2.fromOffset(240, h + 12)
        content.CanvasSize = UDim2.fromOffset(0, layout.AbsoluteContentSize.Y + 12)
    end)

    local inContact = false

    roundBg.InputBegan:Connect(function(input: InputObject)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            if library.activePopup then library.activePopup:Close() end
            local pos = main.AbsolutePosition
            option.mainHolder.Position = UDim2.fromOffset(pos.X - 5, pos.Y - 10)
            option.open = true
            option.mainHolder.Visible = true
            library.activePopup = option
            content.ScrollBarThickness = 6
            tween(option.mainHolder, T_SMOOTH, { ImageTransparency = 0, Position = UDim2.fromOffset(pos.X - 5, pos.Y + 1) })
            for _, label in content:GetChildren() do
                if label:IsA("TextLabel") then
                    tween(label, T_SMOOTH, { BackgroundTransparency = 0, TextTransparency = 0 })
                end
            end
        end
        if input.UserInputType == Enum.UserInputType.MouseMovement then
            inContact = true
            if not option.open then tween(roundBg, T_QUICK, { ImageColor3 = Color3.fromRGB(60, 60, 60) }) end
        end
    end)

    roundBg.InputEnded:Connect(function(input: InputObject)
        if input.UserInputType == Enum.UserInputType.MouseMovement then
            inContact = false
            if not option.open then tween(roundBg, T_QUICK, { ImageColor3 = Color3.fromRGB(40, 40, 40) }) end
        end
    end)

    function option:AddValue(value: string)
        valueCount += 1
        local label = library:Create("TextLabel", {
            ZIndex = 3,
            Size = UDim2.new(1, 0, 0, 40),
            BackgroundColor3 = Color3.fromRGB(30, 30, 30),
            BorderSizePixel = 0,
            Text = "    " .. value,
            TextSize = 14,
            TextTransparency = if self.open then 0 else 1,
            Font = Enum.Font.Gotham,
            TextColor3 = Color3.fromRGB(255, 255, 255),
            TextXAlignment = Enum.TextXAlignment.Left,
            Parent = content,
        }) :: TextLabel

        local lContact = false
        local clicking = false

        label.InputBegan:Connect(function(inp: InputObject)
            if inp.UserInputType == Enum.UserInputType.MouseButton1 then
                clicking = true
                tween(label, T_NORMAL, { BackgroundColor3 = Color3.fromRGB(10, 10, 10) })
                self:SetValue(value)
            end
            if inp.UserInputType == Enum.UserInputType.MouseMovement then
                lContact = true
                if not clicking then tween(label, T_QUICK, { BackgroundColor3 = Color3.fromRGB(20, 20, 20) }) end
            end
        end)

        label.InputEnded:Connect(function(inp: InputObject)
            if inp.UserInputType == Enum.UserInputType.MouseButton1 then
                clicking = false
                tween(label, T_NORMAL, { BackgroundColor3 = if lContact then Color3.fromRGB(20, 20, 20) else Color3.fromRGB(30, 30, 30) })
            end
            if inp.UserInputType == Enum.UserInputType.MouseMovement then
                lContact = false
                if not clicking then tween(label, T_QUICK, { BackgroundColor3 = Color3.fromRGB(30, 30, 30) }) end
            end
        end)
    end

    if not table.find(option.values, option.value) then option:AddValue(option.value) end
    for _, v in option.values do option:AddValue(tostring(v)) end

    function option:RemoveValue(value: string)
        for _, label in content:GetChildren() do
            if label:IsA("TextLabel") and label.Text == "    " .. value then
                label:Destroy()
                valueCount -= 1
                break
            end
        end
        if self.value == value then self:SetValue("") end
    end

    function option:SetValue(value: string)
        library.flags[self.flag] = tostring(value)
        self.value = tostring(value)
        listLabel.Text = self.value
        self.callback(value)
    end

    function option:Close()
        library.activePopup = nil
        self.open = false
        content.ScrollBarThickness = 0
        local pos = main.AbsolutePosition
        tween(roundBg, T_NORMAL, { ImageColor3 = if inContact then Color3.fromRGB(60, 60, 60) else Color3.fromRGB(40, 40, 40) })
        tween(self.mainHolder, T_SMOOTH, { ImageTransparency = 1, Position = UDim2.fromOffset(pos.X - 5, pos.Y - 10) })
        for _, label in content:GetChildren() do
            if label:IsA("TextLabel") then
                tween(label, T_SMOOTH, { BackgroundTransparency = 1, TextTransparency = 1 })
            end
        end
        task.delay(0.35, function()
            if not self.open then self.mainHolder.Visible = false end
        end)
    end

    return option
end

