------------------------------ Sectioning System --------------------------
type SnapEdge = "top" | "bottom" | "left" | "right" | nil

local function getWindowFromMain(mainBtn: Instance): any?
    for _, w in library.windows do
        if w.main == mainBtn then return w end
    end
    return nil
end

local function getSnapTarget(draggedWindow: any): (any?, SnapEdge)
    if not library._sectionEnabled then return nil, nil end
    if not draggedWindow or not draggedWindow.main then return nil, nil end

    local dragBtn: GuiObject = draggedWindow.main
    local dragPos = dragBtn.AbsolutePosition
    local dragSize = dragBtn.AbsoluteSize
    local dragCenterX = dragPos.X + dragSize.X / 2
    local dragCenterY = dragPos.Y + dragSize.Y / 2
    local threshold = library._snapThreshold

    local bestTarget: any? = nil
    local bestEdge: SnapEdge = nil
    local bestDist: number = math.huge

    for _, window in library.windows do
        if window == draggedWindow then continue end
        if not window.main then continue end
        -- Skip if already in same section
        if draggedWindow._sectionId and window._sectionId and draggedWindow._sectionId == window._sectionId then
            continue
        end

        local btn: GuiObject = window.main
        local pos = btn.AbsolutePosition
        local size = btn.AbsoluteSize

        -- Check each edge
        -- Bottom edge of target (we're dragging BELOW it)
        local bottomEdgeY = pos.Y + size.Y
        local distBottom = math.abs(dragCenterY - bottomEdgeY)
        local withinX = dragCenterX >= pos.X - threshold and dragCenterX <= pos.X + size.X + threshold
        if distBottom < threshold and withinX and distBottom < bestDist then
            bestDist = distBottom
            bestTarget = window
            bestEdge = "bottom"
        end

        -- Top edge of target (we're dragging ABOVE it)
        local distTop = math.abs(dragCenterY - pos.Y)
        if distTop < threshold and withinX and distTop < bestDist then
            bestDist = distTop
            bestTarget = window
            bestEdge = "top"
        end

        -- Right edge of target (we're dragging to the RIGHT)
        local rightEdgeX = pos.X + size.X
        local distRight = math.abs(dragCenterX - rightEdgeX)
        local withinY = dragCenterY >= pos.Y - threshold and dragCenterY <= pos.Y + size.Y + threshold
        if distRight < threshold and withinY and distRight < bestDist then
            bestDist = distRight
            bestTarget = window
            bestEdge = "right"
        end

        -- Left edge of target (we're dragging to the LEFT)
        local distLeft = math.abs(dragCenterX - pos.X)
        if distLeft < threshold and withinY and distLeft < bestDist then
            bestDist = distLeft
            bestTarget = window
            bestEdge = "left"
        end
    end

    return bestTarget, bestEdge
end

local function showSnapPreview(target: any, edge: SnapEdge)
    if not library._sectionPreview then return end
    local preview: Frame = library._sectionPreview :: Frame

    if not target or not edge or not target.main then
        preview.Visible = false
        return
    end

    local btn: GuiObject = target.main
    local pos = btn.AbsolutePosition
    local size = btn.AbsoluteSize

    preview.Visible = true

    if edge == "bottom" then
        preview.Position = UDim2.fromOffset(pos.X, pos.Y + size.Y)
        preview.Size = UDim2.fromOffset(size.X, 4)
    elseif edge == "top" then
        preview.Position = UDim2.fromOffset(pos.X, pos.Y - 4)
        preview.Size = UDim2.fromOffset(size.X, 4)
    elseif edge == "right" then
        preview.Position = UDim2.fromOffset(pos.X + size.X, pos.Y)
        preview.Size = UDim2.fromOffset(4, size.Y)
    elseif edge == "left" then
        preview.Position = UDim2.fromOffset(pos.X - 4, pos.Y)
        preview.Size = UDim2.fromOffset(4, size.Y)
    end

    tween(preview, T_QUICK, { BackgroundTransparency = 0.4 })
end

local function hideSnapPreview()
    if not library._sectionPreview then return end
    local preview: Frame = library._sectionPreview :: Frame
    tween(preview, T_QUICK, { BackgroundTransparency = 1 })
    task.delay(0.15, function()
        if preview.BackgroundTransparency > 0.9 then
            preview.Visible = false
        end
    end)
end

local function performSnap(draggedWindow: any, target: any, edge: SnapEdge)
    if not draggedWindow or not target or not edge then return end
    if not draggedWindow.main or not target.main then return end

    local dragBtn: GuiObject = draggedWindow.main
    local targetBtn: GuiObject = target.main
    local tPos = targetBtn.AbsolutePosition
    local tSize = targetBtn.AbsoluteSize
    local dSize = dragBtn.AbsoluteSize

    local finalPos: UDim2

    if edge == "bottom" then
        finalPos = UDim2.fromOffset(tPos.X, tPos.Y + tSize.Y + 2)
    elseif edge == "top" then
        finalPos = UDim2.fromOffset(tPos.X, tPos.Y - dSize.Y - 2)
    elseif edge == "right" then
        finalPos = UDim2.fromOffset(tPos.X + tSize.X + 2, tPos.Y)
    elseif edge == "left" then
        finalPos = UDim2.fromOffset(tPos.X - dSize.X - 2, tPos.Y)
    else
        return
    end

    -- Tween to snapped position
    tween(dragBtn, T_SMOOTH, { Position = finalPos })

    -- Assign section IDs
    local sectionId = target._sectionId or tostring(tick()) .. "_section"
    target._sectionId = sectionId
    draggedWindow._sectionId = sectionId

    -- Update stored positions
    task.delay(0.4, function()
        library._originalPositions[dragBtn] = finalPos
    end)

    -- Track section
    local found = false
    for _, section in library._sections do
        if section.id == sectionId then
            if not table.find(section.windows, draggedWindow) then
                table.insert(section.windows, draggedWindow)
            end
            found = true
            break
        end
    end
    if not found then
        table.insert(library._sections, {
            id = sectionId,
            windows = { target, draggedWindow },
            direction = if edge == "top" or edge == "bottom" then "vertical" else "horizontal",
        })
    end
end

local function unsectionWindow(window: any)
    if not window._sectionId then return end
    local sid = window._sectionId
    window._sectionId = nil

    for i, section in library._sections do
        if section.id == sid then
            for j, w in section.windows do
                if w == window then
                    table.remove(section.windows, j)
                    break
                end
            end
            -- If only one window left, remove the section
            if #section.windows <= 1 then
                if section.windows[1] then
                    section.windows[1]._sectionId = nil
                end
                table.remove(library._sections, i)
            end
            break
        end
    end
end

------------------------------ Loading throbber ---------------------------
local function createThrobber(parent: ScreenGui): { spinner: ImageLabel, bg: Frame, destroy: () -> () }
    local bg = library:Create("Frame", {
        Name = "LoadingBG",
        Size = UDim2.fromScale(1, 1),
        BackgroundColor3 = Color3.fromRGB(10, 10, 10),
        BackgroundTransparency = 1,
        ZIndex = 200,
        Parent = parent,
    }) :: Frame

    local spinner = library:Create("ImageLabel", {
        Name = "Throbber",
        AnchorPoint = Vector2.new(0.5, 0.5),
        Position = UDim2.fromScale(0.5, 0.5),
        Size = UDim2.fromOffset(42, 42),
        BackgroundTransparency = 1,
        Image = "rbxassetid://4965945816",
        ImageColor3 = ACCENT,
        ImageTransparency = 1,
        ZIndex = 201,
        Parent = bg,
    }) :: ImageLabel

    -- Executor name below spinner
    local execLabel = library:Create("TextLabel", {
        AnchorPoint = Vector2.new(0.5, 0),
        Position = UDim2.new(0.5, 0, 0.5, 30),
        Size = UDim2.fromOffset(200, 20),
        BackgroundTransparency = 1,
        Text = _env.executor_name,
        TextColor3 = Color3.fromRGB(80, 80, 80),
        TextTransparency = 1,
        TextSize = 13,
        Font = Enum.Font.Gotham,
        ZIndex = 201,
        Parent = bg,
    }) :: TextLabel

    tween(bg, T_FADE, { BackgroundTransparency = 0.08 })
    tween(spinner, T_FADE, { ImageTransparency = 0 })
    tween(execLabel, T_FADE, { TextTransparency = 0.3 })

    local spinning = true
    local speed = 360

    task.spawn(function()
        while spinning do
            local dt = task.wait()
            spinner.Rotation += speed * dt
        end
    end)

    local function destroy()
        -- Decelerate
        task.spawn(function()
            while speed > 0 do
                speed = math.max(speed - 15, 0)
                task.wait(0.016)
            end
            spinning = false
        end)

        -- Synchronized fade out of throbber elements
        local fadeDur = TweenInfo.new(0.5, Enum.EasingStyle.Sine, Enum.EasingDirection.Out)
        tween(spinner, fadeDur, { ImageTransparency = 1 })
        tween(execLabel, fadeDur, { TextTransparency = 1 })
        tween(bg, TweenInfo.new(0.6, Enum.EasingStyle.Sine, Enum.EasingDirection.Out), { BackgroundTransparency = 1 })
        task.delay(0.65, function()
            bg:Destroy()
        end)
    end

    return { spinner = spinner, bg = bg, destroy = destroy }
end

