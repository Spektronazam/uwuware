------------------------------ Utility helpers ----------------------------
local function round(num: number, bracket: number?): number
    local b = bracket or 1
    local a = math.floor(num / b + math.sign(num) * 0.5) * b
    if a < 0 then a += b end
    return a
end

local function contains<T>(list: { T }, item: T): boolean
    for _, v in list do
        if v == item then return true end
    end
    return false
end

local function tween(obj: Instance, info: TweenInfo, props: { [string]: any })
    TweenService:Create(obj, info, props):Play()
end

local function tweenAwait(obj: Instance, info: TweenInfo, props: { [string]: any })
    local tw = TweenService:Create(obj, info, props)
    tw:Play()
    tw.Completed:Wait()
end

local function updateDrag(input: InputObject)
    if not dragObject or not dragStart or not startPos then return end
    local delta = input.Position - dragStart
    local yPos = math.max(startPos.Y.Offset + delta.Y, -36)
    local target = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, yPos)
    tween(dragObject, T_QUICK, { Position = target })
end

------------------------------ Synchronized Fade System -------------------
--[[
    The core problem with the old library: fading out would miss children,
    or children would fade at different rates, or some wouldn't fade at all.
    
    Solution: before ANY fade, we crawl the entire tree, cache every single
    transparency property, then tween them ALL with the same TweenInfo.
    On fade-in, we restore from cache.
]]

local TRANSPARENCY_PROPS: { [string]: { string } } = {
    Frame = { "BackgroundTransparency" },
    TextLabel = { "BackgroundTransparency", "TextTransparency", "TextStrokeTransparency" },
    TextButton = { "BackgroundTransparency", "TextTransparency", "TextStrokeTransparency" },
    TextBox = { "BackgroundTransparency", "TextTransparency", "TextStrokeTransparency" },
    ImageLabel = { "BackgroundTransparency", "ImageTransparency" },
    ImageButton = { "BackgroundTransparency", "ImageTransparency" },
    ScrollingFrame = { "BackgroundTransparency", "ScrollBarImageTransparency" },
    ViewportFrame = { "BackgroundTransparency", "ImageTransparency" },
    CanvasGroup = { "BackgroundTransparency", "GroupTransparency" },
}

local function cacheTransparency(root: Instance)
    local cache: { [Instance]: { [string]: number } } = {}

    local function crawl(inst: Instance)
        local className = inst.ClassName
        local props = TRANSPARENCY_PROPS[className]
        if props then
            local entry: { [string]: number } = {}
            for _, prop in props do
                local ok, val = pcall(function() return (inst :: any)[prop] end)
                if ok and typeof(val) == "number" then
                    entry[prop] = val
                end
            end
            if next(entry) then
                cache[inst] = entry
            end
        end
        for _, child in inst:GetChildren() do
            crawl(child)
        end
    end

    crawl(root)
    return cache
end

local function fadeOut(root: Instance, duration: TweenInfo, cache: { [Instance]: { [string]: number } }?)
    -- Cache current state if not provided
    local transparencyData = cache or cacheTransparency(root)

    -- Store in library for fade-in restoration
    library._transparencyCache[root] = transparencyData

    -- Build all tweens FIRST, then play them all at once for perfect sync
    local tweens: { Tween } = {}

    for inst, props in transparencyData do
        local targetProps: { [string]: number } = {}
        for prop, _ in props do
            targetProps[prop] = 1
        end
        table.insert(tweens, TweenService:Create(inst, duration, targetProps))
    end

    -- Fire all simultaneously
    for _, tw in tweens do
        tw:Play()
    end

    -- Return a function to wait for completion
    return function()
        if #tweens > 0 then
            tweens[#tweens].Completed:Wait()
        end
    end
end

local function fadeIn(root: Instance, duration: TweenInfo, cache: { [Instance]: { [string]: number } }?)
    local transparencyData = cache or library._transparencyCache[root]
    if not transparencyData then return function() end end

    -- First, set everything to invisible instantly
    for inst, props in transparencyData do
        for prop, _ in props do
            pcall(function() (inst :: any)[prop] = 1 end)
        end
    end

    -- Build all tweens, then fire
    local tweens: { Tween } = {}

    for inst, props in transparencyData do
        local targetProps: { [string]: number } = {}
        for prop, originalVal in props do
            targetProps[prop] = originalVal
        end
        table.insert(tweens, TweenService:Create(inst, duration, targetProps))
    end

    for _, tw in tweens do
        tw:Play()
    end

    return function()
        if #tweens > 0 then
            tweens[#tweens].Completed:Wait()
        end
    end
end

-- Fade a single window and ALL its children in perfect sync
local function fadeWindowOut(window: any, duration: TweenInfo?): () -> ()
    if not window.main then return function() end end
    local dur = duration or T_FADE
    -- Cache BEFORE fading so we know original values
    local cache = cacheTransparency(window.main)
    return fadeOut(window.main, dur, cache)
end

local function fadeWindowIn(window: any, duration: TweenInfo?): () -> ()
    if not window.main then return function() end end
    local dur = duration or T_FADE
    return fadeIn(window.main, dur)
end

------------------------------ Instance creation ---------------------------
function library:Create(class: string, properties: { [string]: any }?): Instance
    local props = properties or {}
    local inst = Instance.new(class)
    for prop, value in props do
        (inst :: any)[prop] = value
    end
    return inst
end

------------------------------ Section Outline Glow -----------------------
local function createSectionOutline(parent: ScreenGui): Frame
    local outline = library:Create("Frame", {
        Name = "SectionOutline",
        Size = UDim2.fromScale(1, 1),
        Position = UDim2.fromScale(0, 0),
        BackgroundTransparency = 1,
        ZIndex = 150,
        Parent = parent,
    }) :: Frame

    -- Top edge
    local top = library:Create("Frame", {
        Name = "Top",
        Size = UDim2.new(1, 0, 0, 2),
        Position = UDim2.fromOffset(0, 0),
        BackgroundColor3 = ACCENT,
        BackgroundTransparency = 0.3,
        BorderSizePixel = 0,
        ZIndex = 151,
        Parent = outline,
    }) :: Frame

    -- Bottom edge
    local bottom = library:Create("Frame", {
        Name = "Bottom",
        Size = UDim2.new(1, 0, 0, 2),
        Position = UDim2.new(0, 0, 1, -2),
        BackgroundColor3 = ACCENT,
        BackgroundTransparency = 0.3,
        BorderSizePixel = 0,
        ZIndex = 151,
        Parent = outline,
    }) :: Frame

    -- Left edge
    local left = library:Create("Frame", {
        Name = "Left",
        Size = UDim2.new(0, 2, 1, 0),
        Position = UDim2.fromOffset(0, 0),
        BackgroundColor3 = ACCENT,
        BackgroundTransparency = 0.3,
        BorderSizePixel = 0,
        ZIndex = 151,
        Parent = outline,
    }) :: Frame

    -- Right edge
    local right = library:Create("Frame", {
        Name = "Right",
        Size = UDim2.new(0, 2, 1, 0),
        Position = UDim2.new(1, -2, 0, 0),
        BackgroundColor3 = ACCENT,
        BackgroundTransparency = 0.3,
        BorderSizePixel = 0,
        ZIndex = 151,
        Parent = outline,
    }) :: Frame

    -- Glow pulse animation
    local glowUp = true
    local edges = { top, bottom, left, right }

    task.spawn(function()
        while outline.Parent do
            local target = if glowUp then 0.1 else 0.5
            for _, edge in edges do
                tween(edge, TweenInfo.new(1.2, Enum.EasingStyle.Sine, Enum.EasingDirection.InOut), {
                    BackgroundTransparency = target,
                })
            end
            glowUp = not glowUp
            task.wait(1.2)
        end
    end)

    return outline
end

