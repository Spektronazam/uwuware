-- ═══════════ BIND ═══════════
local function createBind(option: OptionBase, parent: any)
    local binding = false
    local loop: RBXScriptConnection? = nil

    local keyText: string = if string.match(option.key, "Mouse")
        then string.sub(option.key, 1, 5) .. string.sub(option.key, 12, 13)
        else option.key

    local main = library:Create("TextLabel", {
        LayoutOrder = option.position,
        Size = UDim2.new(1, 0, 0, 33),
        BackgroundTransparency = 1,
        Text = " " .. option.text,
        TextSize = 17,
        Font = Enum.Font.Gotham,
        TextColor3 = Color3.fromRGB(255, 255, 255),
        TextXAlignment = Enum.TextXAlignment.Left,
        Parent = parent.content,
    }) :: TextLabel

    local textWidth = TextService:GetTextSize(keyText, 16, Enum.Font.Gotham, Vector2.new(1e9, 1e9)).X

    local roundBg = library:Create("ImageLabel", {
        Position = UDim2.new(1, -6, 0, 4),
        Size = UDim2.new(0, -(textWidth + 16), 1, -10),
        SizeConstraint = Enum.SizeConstraint.RelativeYY,
        BackgroundTransparency = 1,
        Image = "rbxassetid://3570695787",
        ImageColor3 = Color3.fromRGB(40, 40, 40),
        ScaleType = Enum.ScaleType.Slice,
        SliceCenter = Rect.new(100, 100, 100, 100),
        SliceScale = 0.02,
        Parent = main,
    }) :: ImageLabel

    local bindLabel = library:Create("TextLabel", {
        Size = UDim2.fromScale(1, 1),
        BackgroundTransparency = 1,
        Text = keyText,
        TextSize = 16,
        Font = Enum.Font.Gotham,
        TextColor3 = Color3.fromRGB(255, 255, 255),
        Parent = roundBg,
    }) :: TextLabel

    local inContact = false

    main.InputBegan:Connect(function(input: InputObject)
        if input.UserInputType == Enum.UserInputType.MouseMovement then
            inContact = true
            if not binding then
                tween(roundBg, T_QUICK, { ImageColor3 = Color3.fromRGB(60, 60, 60) })
            end
        end
    end)

    main.InputEnded:Connect(function(input: InputObject)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            binding = true
            bindLabel.Text = "..."
            tween(roundBg, T_NORMAL, { ImageColor3 = ACCENT })
        end
        if input.UserInputType == Enum.UserInputType.MouseMovement then
            inContact = false
            if not binding then
                tween(roundBg, T_QUICK, { ImageColor3 = Color3.fromRGB(40, 40, 40) })
            end
        end
    end)

    InputService.InputBegan:Connect(function(input: InputObject)
        if not isActive() then return end
        if InputService:GetFocusedTextBox() then return end

        if (input.KeyCode.Name == option.key or input.UserInputType.Name == option.key) and not binding then
            if option.hold then
                loop = RunService.Heartbeat:Connect(function()
                    if binding then
                        option.callback(true)
                        if loop then loop:Disconnect(); loop = nil end
                    else
                        option.callback()
                    end
                end)
            else
                option.callback()
            end
        elseif binding then
            local key: (Enum.KeyCode | Enum.UserInputType)? = nil
            if not contains(BLACKLISTED_KEYS, input.KeyCode) then
                key = input.KeyCode
            end
            if key == nil and contains(WHITELISTED_MOUSE, input.UserInputType) then
                key = input.UserInputType
            end
            option:SetKey(key)
        end
    end)

    InputService.InputEnded:Connect(function(input: InputObject)
        if input.KeyCode.Name == option.key or input.UserInputType.Name == option.key then
            if loop then
                loop:Disconnect()
                loop = nil
                option.callback(true)
            end
        end
    end)

    function option:SetKey(key: any?)
        binding = false
        if loop then loop:Disconnect(); loop = nil end
        self.key = if key then (if typeof(key) == "EnumItem" then key.Name else key) else self.key
        library.flags[self.flag] = self.key
        local display: string = self.key
        if string.match(display, "Mouse") then
            display = string.sub(display, 1, 5) .. string.sub(display, 12, 13)
        end
        bindLabel.Text = display
        tween(roundBg, T_NORMAL, { ImageColor3 = if inContact then Color3.fromRGB(60, 60, 60) else Color3.fromRGB(40, 40, 40) })
        local w = TextService:GetTextSize(display, 15, Enum.Font.Gotham, Vector2.new(1e9, 1e9)).X
        roundBg.Size = UDim2.new(0, -(w + 16), 1, -10)
    end
end

-- ═══════════ SLIDER ═══════════
local function createSlider(option: OptionBase, parent: any)
    local main = library:Create("Frame", {
        LayoutOrder = option.position,
        Size = UDim2.new(1, 0, 0, 50),
        BackgroundTransparency = 1,
        Parent = parent.content,
    }) :: Frame

    library:Create("TextLabel", {
        Position = UDim2.fromOffset(0, 4),
        Size = UDim2.new(1, 0, 0, 20),
        BackgroundTransparency = 1,
        Text = " " .. option.text,
        TextSize = 17,
        Font = Enum.Font.Gotham,
        TextColor3 = Color3.fromRGB(255, 255, 255),
        TextXAlignment = Enum.TextXAlignment.Left,
        Parent = main,
    })

    local slider = library:Create("ImageLabel", {
        Position = UDim2.new(0, 10, 0, 34),
        Size = UDim2.new(1, -20, 0, 5),
        BackgroundTransparency = 1,
        Image = "rbxassetid://3570695787",
        ImageColor3 = Color3.fromRGB(30, 30, 30),
        ScaleType = Enum.ScaleType.Slice,
        SliceCenter = Rect.new(100, 100, 100, 100),
        SliceScale = 0.02,
        Parent = main,
    }) :: ImageLabel

    local fill = library:Create("ImageLabel", {
        BackgroundTransparency = 1,
        Image = "rbxassetid://3570695787",
        ImageColor3 = Color3.fromRGB(60, 60, 60),
        ScaleType = Enum.ScaleType.Slice,
        SliceCenter = Rect.new(100, 100, 100, 100),
        SliceScale = 0.02,
        Parent = slider,
    }) :: ImageLabel

    local ratio: number = (option.value - option.min) / (option.max - option.min)

    local circle = library:Create("ImageLabel", {
        AnchorPoint = Vector2.new(0.5, 0.5),
        Position = UDim2.new(ratio, 0, 0.5, 0),
        SizeConstraint = Enum.SizeConstraint.RelativeYY,
        Size = UDim2.fromOffset(0, 0),
        BackgroundTransparency = 1,
        Image = "rbxassetid://3570695787",
        ImageColor3 = Color3.fromRGB(60, 60, 60),
        ScaleType = Enum.ScaleType.Slice,
        SliceCenter = Rect.new(100, 100, 100, 100),
        SliceScale = 1,
        Parent = slider,
    }) :: ImageLabel

    local valueRound = library:Create("ImageLabel", {
        Position = UDim2.new(1, -6, 0, 4),
        Size = UDim2.fromOffset(-60, 18),
        BackgroundTransparency = 1,
        Image = "rbxassetid://3570695787",
        ImageColor3 = Color3.fromRGB(40, 40, 40),
        ScaleType = Enum.ScaleType.Slice,
        SliceCenter = Rect.new(100, 100, 100, 100),
        SliceScale = 0.02,
        Parent = main,
    }) :: ImageLabel

    local inputBox = library:Create("TextBox", {
        Size = UDim2.fromScale(1, 1),
        BackgroundTransparency = 1,
        Text = tostring(option.value),
        TextColor3 = Color3.fromRGB(235, 235, 235),
        TextSize = 15,
        TextWrapped = true,
        Font = Enum.Font.Gotham,
        Parent = valueRound,
    }) :: TextBox

    if option.min >= 0 then
        fill.Size = UDim2.new(ratio, 0, 1, 0)
    else
        fill.Position = UDim2.new((0 - option.min) / (option.max - option.min), 0, 0, 0)
        fill.Size = UDim2.new(option.value / (option.max - option.min), 0, 1, 0)
    end

    local sliding = false
    local inContact = false

    main.InputBegan:Connect(function(input: InputObject)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            tween(fill, T_NORMAL, { ImageColor3 = ACCENT })
            tween(circle, T_NORMAL, { Size = UDim2.new(3.5, 0, 3.5, 0), ImageColor3 = ACCENT })
            sliding = true
            option:SetValue(option.min + ((input.Position.X - slider.AbsolutePosition.X) / slider.AbsoluteSize.X) * (option.max - option.min))
        end
        if input.UserInputType == Enum.UserInputType.MouseMovement then
            inContact = true
            if not sliding then
                tween(fill, T_NORMAL, { ImageColor3 = Color3.fromRGB(100, 100, 100) })
                tween(circle, T_NORMAL, { Size = UDim2.new(2.8, 0, 2.8, 0), ImageColor3 = Color3.fromRGB(100, 100, 100) })
            end
        end
    end)

    InputService.InputChanged:Connect(function(input: InputObject)
        if input.UserInputType == Enum.UserInputType.MouseMovement and sliding then
            option:SetValue(option.min + ((input.Position.X - slider.AbsolutePosition.X) / slider.AbsoluteSize.X) * (option.max - option.min))
        end
    end)

    main.InputEnded:Connect(function(input: InputObject)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            sliding = false
            local c = if inContact then Color3.fromRGB(100, 100, 100) else Color3.fromRGB(60, 60, 60)
            local s = if inContact then UDim2.new(2.8, 0, 2.8, 0) else UDim2.new(0, 0, 0, 0)
            tween(fill, T_NORMAL, { ImageColor3 = c })
            tween(circle, T_NORMAL, { Size = s, ImageColor3 = c })
        end
        if input.UserInputType == Enum.UserInputType.MouseMovement then
            inContact = false
            inputBox:ReleaseFocus()
            if not sliding then
                tween(fill, T_NORMAL, { ImageColor3 = Color3.fromRGB(60, 60, 60) })
                tween(circle, T_NORMAL, { Size = UDim2.new(0, 0, 0, 0), ImageColor3 = Color3.fromRGB(60, 60, 60) })
            end
        end
    end)

    inputBox.FocusLost:Connect(function()
        tween(circle, T_NORMAL, { Size = UDim2.new(0, 0, 0, 0), ImageColor3 = Color3.fromRGB(60, 60, 60) })
        option:SetValue(tonumber(inputBox.Text) or option.value)
    end)

    function option:SetValue(value: number)
        value = round(value, self.float)
        value = math.clamp(value, self.min, self.max)
        local r = (value - self.min) / (self.max - self.min)
        tween(circle, T_QUICK, { Position = UDim2.new(r, 0, 0.5, 0) })
        if self.min >= 0 then
            tween(fill, T_QUICK, { Size = UDim2.new(r, 0, 1, 0) })
        else
            tween(fill, T_QUICK, { Position = UDim2.new((0 - self.min) / (self.max - self.min), 0, 0, 0) })
            tween(fill, T_QUICK, { Size = UDim2.new(value / (self.max - self.min), 0, 1, 0) })
        end
        library.flags[self.flag] = value
        self.value = value
        inputBox.Text = tostring(value)
        self.callback(value)
    end
end

